#!/usr/bin/env bash
set -euo pipefail

# agent-bridge — Bridge AI coding agents across machines.
# Pure bash. Zero dependencies. Works on any Mac/Linux out of the box.
# https://github.com/EthanSK/agent-bridge
#
# Previously known as claude-bridge.

INVOKED_AS="$(basename "$0")"

VERSION="3.0.0"

# -- Colours (ANSI) ----------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# -- Deprecation notice -------------------------------------------------------
if [ "$INVOKED_AS" = "claude-bridge" ]; then
  printf '\033[0;33m  [deprecated] "claude-bridge" has been renamed to "agent-bridge". Please update your scripts.\033[0m\n' >&2
fi

# -- Paths --------------------------------------------------------------------
CONFIG_DIR="$HOME/.agent-bridge"
CONFIG_FILE="$CONFIG_DIR/config"
KEYS_DIR="$CONFIG_DIR/keys"

# Migrate from old config dir if it exists and new one doesn't
if [ ! -d "$CONFIG_DIR" ] && [ -d "$HOME/.claude-bridge" ]; then
  mv "$HOME/.claude-bridge" "$CONFIG_DIR"
fi

# -- Helpers ------------------------------------------------------------------
die()  { printf "${RED}  Error: %s${RESET}\n" "$1" >&2; exit 1; }
info() { printf "${CYAN}%s${RESET}\n" "$1"; }
ok()   { printf "${GREEN}  [ok] %s${RESET}\n" "$1"; }
warn() { printf "${YELLOW}  %s${RESET}\n" "$1"; }
dim()  { printf "${DIM}  %s${RESET}\n" "$1"; }

ensure_config_dir() {
  [ -d "$CONFIG_DIR" ] || mkdir -p "$CONFIG_DIR" && chmod 700 "$CONFIG_DIR"
  [ -d "$KEYS_DIR" ]   || mkdir -p "$KEYS_DIR"   && chmod 700 "$KEYS_DIR"
  [ -f "$CONFIG_FILE" ] || touch "$CONFIG_FILE"   && chmod 600 "$CONFIG_FILE"
}

# -- INI-style config parser --------------------------------------------------
# Config format:
#   [MacBook-Pro]
#   host=MacBookPro.local
#   user=ethansk
#   port=22
#   key=~/.agent-bridge/keys/MacBook-Pro
#   paired_at=2026-04-09T12:00:00

# Get a value for a machine: cfg_get <machine> <key>
cfg_get() {
  local machine="$1" key="$2"
  if [ ! -f "$CONFIG_FILE" ]; then
    return 1
  fi
  local in_section=0
  while IFS= read -r line || [ -n "$line" ]; do
    # Strip carriage returns
    line="${line%$'\r'}"
    # Check for section header (case-insensitive match)
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$(printf '%s' "$section" | tr '[:upper:]' '[:lower:]')" = "$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')" ]; then
        in_section=1
      else
        in_section=0
      fi
      continue
    fi
    if [ "$in_section" = "1" ] && [[ "$line" =~ ^${key}=(.*)$ ]]; then
      printf '%s' "${BASH_REMATCH[1]}"
      return 0
    fi
  done < "$CONFIG_FILE"
  return 1
}

# Check if a machine exists (case-insensitive)
cfg_exists() {
  local machine="$1"
  local lower_machine
  lower_machine="$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')"
  if [ ! -f "$CONFIG_FILE" ]; then
    return 1
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$(printf '%s' "$section" | tr '[:upper:]' '[:lower:]')" = "$lower_machine" ]; then
        return 0
      fi
    fi
  done < "$CONFIG_FILE"
  return 1
}

# Get the exact section name (preserving original case)
cfg_real_name() {
  local machine="$1"
  local lower_machine
  lower_machine="$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')"
  if [ ! -f "$CONFIG_FILE" ]; then
    return 1
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$(printf '%s' "$section" | tr '[:upper:]' '[:lower:]')" = "$lower_machine" ]; then
        printf '%s' "$section"
        return 0
      fi
    fi
  done < "$CONFIG_FILE"
  return 1
}

# Save a machine config (overwrites if exists)
cfg_save() {
  local machine="$1" host="$2" user="$3" port="$4" keypath="$5"
  ensure_config_dir

  # Remove existing section first
  cfg_remove "$machine" 2>/dev/null || true

  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # Expand ~ in keypath
  keypath="${keypath/#\~/$HOME}"

  {
    printf '[%s]\n' "$machine"
    printf 'host=%s\n' "$host"
    printf 'user=%s\n' "$user"
    printf 'port=%s\n' "$port"
    printf 'key=%s\n' "$keypath"
    printf 'paired_at=%s\n' "$ts"
    printf '\n'
  } >> "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
}

# Remove a machine section
cfg_remove() {
  local machine="$1"
  if ! cfg_exists "$machine"; then
    return 1
  fi
  local real_name
  real_name="$(cfg_real_name "$machine")"
  local tmpfile
  tmpfile="$(mktemp)"
  local in_section=0
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$section" = "$real_name" ]; then
        in_section=1
        continue
      else
        in_section=0
      fi
    fi
    if [ "$in_section" = "1" ]; then
      # Skip lines in the removed section
      continue
    fi
    printf '%s\n' "$line"
  done < "$CONFIG_FILE" > "$tmpfile"
  mv "$tmpfile" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
}

# List all machine names
cfg_list_names() {
  if [ ! -f "$CONFIG_FILE" ]; then
    return
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      printf '%s\n' "${BASH_REMATCH[1]}"
    fi
  done < "$CONFIG_FILE"
}

# Set or update a single key within an existing machine section
cfg_set() {
  local machine="$1" key="$2" value="$3"
  if ! cfg_exists "$machine"; then
    die "Machine \"$machine\" not found in config."
  fi
  local real_name
  real_name="$(cfg_real_name "$machine")"
  local tmpfile
  tmpfile="$(mktemp)"
  local in_section=0 key_written=0
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      # If leaving our section and we haven't written the key yet, append it
      if [ "$in_section" = "1" ] && [ "$key_written" = "0" ]; then
        printf '%s=%s\n' "$key" "$value" >> "$tmpfile"
        key_written=1
      fi
      if [ "$section" = "$real_name" ]; then
        in_section=1
      else
        in_section=0
      fi
      printf '%s\n' "$line" >> "$tmpfile"
      continue
    fi
    if [ "$in_section" = "1" ] && [[ "$line" =~ ^${key}= ]]; then
      # Replace existing key
      printf '%s=%s\n' "$key" "$value" >> "$tmpfile"
      key_written=1
      continue
    fi
    printf '%s\n' "$line" >> "$tmpfile"
  done < "$CONFIG_FILE"
  # If still in section at EOF and key not written, append it
  if [ "$in_section" = "1" ] && [ "$key_written" = "0" ]; then
    printf '%s=%s\n' "$key" "$value" >> "$tmpfile"
  fi
  mv "$tmpfile" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
}

# -- Tunnel config helpers ----------------------------------------------------
TUNNEL_CONFIG_FILE="$CONFIG_DIR/tunnel-config"
LAUNCH_AGENT_LABEL="com.ethansk.agent-bridge-tunnel"
LAUNCH_AGENT_PLIST="$HOME/Library/LaunchAgents/${LAUNCH_AGENT_LABEL}.plist"

tunnel_config_get() {
  local key="$1"
  if [ ! -f "$TUNNEL_CONFIG_FILE" ]; then
    return 1
  fi
  # Simple JSON field extraction (no jq dependency)
  local val
  val="$(grep -o "\"${key}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$TUNNEL_CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*":\s*"//' | sed 's/"$//')"
  if [ -n "$val" ]; then
    printf '%s' "$val"
    return 0
  fi
  # Try boolean/number fields
  val="$(grep -o "\"${key}\"[[:space:]]*:[[:space:]]*[^,}]*" "$TUNNEL_CONFIG_FILE" 2>/dev/null | head -1 | sed 's/.*:\s*//' | tr -d ' ')"
  if [ -n "$val" ]; then
    printf '%s' "$val"
    return 0
  fi
  return 1
}

# -- SSH helpers with dual-endpoint fallback ----------------------------------
# Try LAN first (3s timeout), fall back to internet_host if configured.
# Usage: ssh_with_fallback <machine> <ssh_args...>
# Sets SSH_FALLBACK_USED=1 if internet fallback was used.
SSH_FALLBACK_USED=0

ssh_build_args_for() {
  # Build SSH args for a specific host:port
  local machine="$1" host="$2" port="$3" timeout="$4"
  local keypath
  keypath="$(cfg_get "$machine" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=${timeout}" "-p" "$port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath")
  fi
  args+=("$(cfg_get "$machine" user)@${host}")

  printf '%s\n' "${args[@]}"
}

ssh_exec_with_fallback() {
  local machine="$1"
  shift
  local extra_args=("$@")

  local host port internet_host internet_port
  host="$(cfg_get "$machine" host)" || die "Machine \"$machine\" not found."
  port="$(cfg_get "$machine" port 2>/dev/null || printf '22')"
  internet_host="$(cfg_get "$machine" internet_host 2>/dev/null || true)"
  internet_port="$(cfg_get "$machine" internet_port 2>/dev/null || printf '22')"

  local has_fallback=0
  [ -n "$internet_host" ] && has_fallback=1

  local lan_timeout=10
  [ "$has_fallback" = "1" ] && lan_timeout=3

  SSH_FALLBACK_USED=0

  # Try LAN
  local lan_args
  readarray -t lan_args < <(ssh_build_args_for "$machine" "$host" "$port" "$lan_timeout")
  lan_args+=("${extra_args[@]}")

  local lan_exit=0
  ssh "${lan_args[@]}" || lan_exit=$?

  # Only fallback on SSH connection failure (exit 255)
  if [ "$lan_exit" -ne 255 ] || [ "$has_fallback" = "0" ]; then
    return "$lan_exit"
  fi

  # Try internet fallback
  SSH_FALLBACK_USED=1
  local inet_args
  readarray -t inet_args < <(ssh_build_args_for "$machine" "$internet_host" "$internet_port" "10")
  inet_args+=("${extra_args[@]}")

  local inet_exit=0
  ssh "${inet_args[@]}" || inet_exit=$?
  return "$inet_exit"
}

# -- Network helpers ----------------------------------------------------------
get_local_ip() {
  if command -v ipconfig >/dev/null 2>&1; then
    # macOS
    local ip
    ip="$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || true)"
    if [ -n "$ip" ]; then
      printf '%s' "$ip"
      return
    fi
  fi
  # Linux / fallback
  if command -v hostname >/dev/null 2>&1; then
    local ip
    ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
    if [ -n "$ip" ]; then
      printf '%s' "$ip"
      return
    fi
  fi
  # Last resort
  if command -v ifconfig >/dev/null 2>&1; then
    local ip
    ip="$(ifconfig 2>/dev/null | grep 'inet ' | grep -v '127.0.0.1' | head -1 | awk '{print $2}')"
    if [ -n "$ip" ]; then
      printf '%s' "$ip"
      return
    fi
  fi
  printf 'unknown'
}

get_public_ip() {
  curl -s --max-time 3 ifconfig.me 2>/dev/null || printf 'unavailable'
}

get_hostname() {
  hostname 2>/dev/null || printf 'unknown'
}

get_machine_name() {
  local h
  h="$(get_hostname)"
  # Strip .local suffix
  printf '%s' "${h%.local}"
}

get_username() {
  whoami 2>/dev/null || printf '%s' "$USER"
}

generate_pairing_token() {
  local hex
  hex="$(head -c 4 /dev/urandom | xxd -p | head -c 6)"
  printf 'bridge-%s' "$hex"
}

is_macos() {
  [ "$(uname -s)" = "Darwin" ]
}

# -- SSH helpers --------------------------------------------------------------
ssh_build_args() {
  local machine="$1"
  local host user port keypath
  host="$(cfg_get "$machine" host)" || die "Machine \"$machine\" not found."
  user="$(cfg_get "$machine" user)" || die "No user for \"$machine\"."
  port="$(cfg_get "$machine" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine" key 2>/dev/null || true)"

  # Expand ~ in keypath
  keypath="${keypath/#\~/$HOME}"

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-p" "$port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath")
  fi
  args+=("${user}@${host}")

  printf '%s\n' "${args[@]}"
}

# -- Harness instruction files ------------------------------------------------
# After setup/pair, append agent-bridge instructions to detected AI harness
# config files (CLAUDE.md, AGENTS.md, GEMINI.md) so every new session knows
# about the bridge.

HARNESS_MARKER_START="<!-- agent-bridge:start -->"
HARNESS_MARKER_END="<!-- agent-bridge:end -->"

harness_instruction_block() {
  cat <<'BLOCK'
<!-- agent-bridge:start -->
## Agent Bridge

This machine has agent-bridge installed for cross-machine communication.

Paired machines (check with `agent-bridge list`):
- Run `agent-bridge status` to check which machines are reachable
- Run `agent-bridge run <machine> "command"` to execute a plain shell command remotely (diagnostics only — e.g. `git status`, `ls`, `ps aux`)
- Run `agent-bridge connect <machine>` for interactive SSH

To talk to the RUNNING agent on another paired machine, use the channel plugin's
`bridge_send_message` MCP tool. This is the ONLY supported way to communicate
agent-to-agent. `agent-bridge run` does NOT invoke a remote agent — it is a plain
remote-shell utility. There are no `--claude` / `--codex` / `--agent` flags.

Config: `~/.agent-bridge/config` | Keys: `~/.agent-bridge/keys/`

If a paired machine is unreachable, check if it's powered on and SSH (Remote Login) is enabled.
<!-- agent-bridge:end -->
BLOCK
}

# Update a single harness instruction file. Idempotent: replaces existing block
# or appends if not present.
# Usage: harness_update_file <filepath>
harness_update_file() {
  local filepath="$1"
  local block
  block="$(harness_instruction_block)"

  if [ ! -f "$filepath" ]; then
    # File doesn't exist — skip (we don't create files for harnesses that aren't installed)
    return 0
  fi

  if grep -qF "$HARNESS_MARKER_START" "$filepath" 2>/dev/null; then
    # Replace existing block between markers
    local tmpfile
    tmpfile="$(mktemp)"
    local in_block=0
    while IFS= read -r line || [ -n "$line" ]; do
      if [ "$line" = "$HARNESS_MARKER_START" ]; then
        in_block=1
        printf '%s\n' "$block" >> "$tmpfile"
        continue
      fi
      if [ "$in_block" = "1" ]; then
        if [ "$line" = "$HARNESS_MARKER_END" ]; then
          in_block=0
        fi
        continue
      fi
      printf '%s\n' "$line" >> "$tmpfile"
    done < "$filepath"
    mv "$tmpfile" "$filepath"
  else
    # Append block to end of file
    printf '\n%s\n' "$block" >> "$filepath"
  fi
}

# Detect installed harnesses and update their instruction files.
update_harness_instructions() {
  local updated=0

  # Claude Code: ~/.claude/CLAUDE.md
  if [ -f "$HOME/.claude/CLAUDE.md" ]; then
    harness_update_file "$HOME/.claude/CLAUDE.md"
    ok "Updated ~/.claude/CLAUDE.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  # Codex: ~/.codex/AGENTS.md
  if [ -f "$HOME/.codex/AGENTS.md" ]; then
    harness_update_file "$HOME/.codex/AGENTS.md"
    ok "Updated ~/.codex/AGENTS.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  # OpenClaw: ~/.openclaw/AGENTS.md
  if [ -f "$HOME/.openclaw/AGENTS.md" ]; then
    harness_update_file "$HOME/.openclaw/AGENTS.md"
    ok "Updated ~/.openclaw/AGENTS.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  # Gemini CLI: ~/.gemini/GEMINI.md
  if [ -f "$HOME/.gemini/GEMINI.md" ]; then
    harness_update_file "$HOME/.gemini/GEMINI.md"
    ok "Updated ~/.gemini/GEMINI.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  if [ "$updated" -eq 0 ]; then
    dim "No AI harness instruction files detected. Skipping."
  fi
}

# -- Commands -----------------------------------------------------------------

cmd_setup() {
  local machine_name="" port="22" internet=false tunnel_provider="serveo" stop_internet=false
  TUNNEL_PID=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --name|-n)             machine_name="$2"; shift 2 ;;
      --port|-p)             port="$2"; shift 2 ;;
      --internet)            internet=true; shift ;;
      --stop)                stop_internet=true; shift ;;
      --tunnel-provider)     tunnel_provider="$2"; shift 2 ;;
      --help|-h)             cmd_setup_help; exit 0 ;;
      *)                     die "Unknown option: $1. Use --help for usage." ;;
    esac
  done

  # Handle --internet --stop: tear down tunnel
  if [ "$stop_internet" = true ] && [ "$internet" = false ]; then
    die "--stop must be used with --internet. Usage: agent-bridge setup --internet --stop"
  fi
  if [ "$stop_internet" = true ]; then
    printf '\n'
    printf "${BOLD}${CYAN}  Tearing down internet tunnel...${RESET}\n"
    printf '\n'

    if is_macos && [ -f "$LAUNCH_AGENT_PLIST" ]; then
      launchctl unload "$LAUNCH_AGENT_PLIST" 2>/dev/null || true
      rm -f "$LAUNCH_AGENT_PLIST"
      ok "LaunchAgent removed."
    else
      # Kill any running tunnel process
      pkill -f "ssh.*serveo.net" 2>/dev/null || true
      dim "Tunnel process stopped (if running)."
    fi

    if [ -f "$TUNNEL_CONFIG_FILE" ]; then
      rm -f "$TUNNEL_CONFIG_FILE"
      ok "Tunnel config removed."
    else
      dim "No tunnel config found."
    fi
    printf '\n'
    ok "Internet tunnel torn down."
    printf '\n'
    return
  fi

  [ -z "$machine_name" ] && machine_name="$(get_machine_name)"
  local user
  user="$(get_username)"
  local local_hostname
  local_hostname="$(get_hostname)"

  printf '\n'
  printf "${BOLD}${CYAN}  +----------------------------------------------+${RESET}\n"
  printf "${BOLD}${CYAN}  |         agent-bridge  .  setup                |${RESET}\n"
  printf "${BOLD}${CYAN}  +----------------------------------------------+${RESET}\n"
  printf '\n'

  # Step 1: Check/enable SSH
  printf "${BOLD}  1. SSH Server${RESET}\n"
  if is_macos; then
    local ssh_status
    ssh_status="$(sudo systemsetup -getremotelogin 2>/dev/null || printf 'unknown')"
    if printf '%s' "$ssh_status" | grep -qi 'on'; then
      ok "SSH (Remote Login) is already enabled."
    else
      dim "Enabling Remote Login (may require sudo)..."
      if sudo systemsetup -setremotelogin on 2>/dev/null; then
        ok "Remote Login enabled."
      else
        warn "Could not enable Remote Login automatically."
        warn "Enable it manually: System Settings > General > Sharing > Remote Login"
      fi
    fi
  else
    if systemctl is-active --quiet sshd 2>/dev/null || systemctl is-active --quiet ssh 2>/dev/null; then
      ok "SSH server is running."
    elif pgrep -x sshd >/dev/null 2>&1; then
      ok "SSH server is running."
    else
      warn "SSH server does not appear to be running."
      warn "Start it with: sudo systemctl start sshd"
    fi
  fi
  printf '\n'

  # Step 2: Generate key pair
  printf "${BOLD}  2. SSH Key Pair${RESET}\n"
  ensure_config_dir
  local key_path="$KEYS_DIR/agent-bridge_${machine_name}"
  local pub_key_path="${key_path}.pub"

  if [ -f "$key_path" ] && [ -f "$pub_key_path" ]; then
    dim "Using existing key pair."
  else
    dim "Generating SSH key pair..."
    ssh-keygen -t ed25519 -f "$key_path" -N "" -C "agent-bridge:${machine_name}" >/dev/null 2>&1
    chmod 600 "$key_path"
    ok "Key pair generated."
  fi

  # Save identity so pair/run/connect use the same key
  printf '%s' "$key_path" > "$CONFIG_DIR/.identity"

  # Add to authorized_keys
  local ssh_dir="$HOME/.ssh"
  local auth_keys="$ssh_dir/authorized_keys"
  [ -d "$ssh_dir" ] || mkdir -p "$ssh_dir" && chmod 700 "$ssh_dir"
  local pub_key
  pub_key="$(cat "$pub_key_path")"

  if [ -f "$auth_keys" ] && grep -qF "$pub_key" "$auth_keys" 2>/dev/null; then
    dim "Public key already in authorized_keys."
  else
    printf '%s\n' "$pub_key" >> "$auth_keys"
    chmod 600 "$auth_keys"
    ok "Public key added to authorized_keys."
  fi

  # Fingerprint
  local fingerprint
  fingerprint="$(ssh-keygen -lf "$pub_key_path" 2>/dev/null | awk '{print $2}' || printf 'unknown')"
  printf '\n'

  # Step 2b: Check Full Disk Access (macOS only)
  if is_macos; then
    printf "${BOLD}  2b. Full Disk Access${RESET}\n"
    # FDA cannot be reliably detected without root, and "ls ~/Desktop"
    # always succeeds locally. Just inform the user.
    warn "SSH sessions need Full Disk Access to reach Desktop, Documents, Downloads, etc."
    dim "Add /usr/sbin/sshd in System Settings > Privacy & Security > Full Disk Access."
    dim "Skip this if it's already there — you can always do it later."
    printf '\n'
  fi

  # Step 3: Get network info
  local primary_ip
  primary_ip="$(get_local_ip)"
  local public_ip
  public_ip="$(get_public_ip)"

  # Step 4: Generate pairing token
  printf "${BOLD}  3. Pairing Token${RESET}\n"
  local pairing_token
  pairing_token="$(generate_pairing_token)"
  ensure_config_dir
  printf '%s' "$pairing_token" > "$CONFIG_DIR/.pending-token"
  chmod 600 "$CONFIG_DIR/.pending-token"
  ok "One-time pairing token generated."
  printf '\n'

  # Step 5: Display pairing screen
  # Calculate box width — wide enough for the public key
  local pub_key_display="$pub_key"
  local pub_key_len=${#pub_key_display}
  local min_width=46
  local needed_width=$(( pub_key_len + 16 ))
  local box_width=$min_width
  [ "$needed_width" -gt "$box_width" ] && box_width=$needed_width
  local inner_width=$((box_width - 4))

  printf '\n'
  printf "${BOLD}${CYAN}"
  printf '  ╔'; printf '═%.0s' $(seq 1 $box_width); printf '╗\n'
  printf '  ║%*s%s%*s║\n' $(( (box_width - 21) / 2 )) "" "agent-bridge pairing" $(( (box_width - 20) / 2 )) ""
  printf '  ╠'; printf '═%.0s' $(seq 1 $box_width); printf '╣\n'
  printf "${RESET}"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Machine:${RESET}    %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$machine_name"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}User:${RESET}       %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$user"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Local:${RESET}      %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$local_hostname"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Local IP:${RESET}   %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$primary_ip"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Public IP:${RESET}  %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$public_ip"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Port:${RESET}       %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$port"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Token:${RESET}      ${YELLOW}${BOLD}%-*s${RESET}${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$pairing_token"
  printf "${BOLD}${CYAN}  ╠"; printf '═%.0s' $(seq 1 $box_width); printf "╣${RESET}\n"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Public Key:${RESET} %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$pub_key_display"
  printf "${BOLD}${CYAN}"
  printf '  ╚'; printf '═%.0s' $(seq 1 $box_width); printf '╝\n'
  printf "${RESET}"
  printf '\n'
  dim "Photograph this screen and send to Claude on your other machine."
  if [ "$internet" = false ]; then
    dim "For internet access, see 'Internet connectivity (Tailscale)' in the README."
  fi
  printf '\n'

  # Internet tunnel — pinned subdomain + persistent LaunchAgent
  # DEPRECATED 2026-04-17: Serveo's free tier does not route raw TCP/SSH on subdomains
  # (subdomain:22 hits Serveo's own sshd, not the tunnel). Flag retained for back-compat
  # but emits a prominent warning. See commit 8bdc4a0 and README Internet connectivity
  # section for the Tailscale replacement.
  if [ "$internet" = true ]; then
    printf "\n"
    printf "${BOLD}${YELLOW}  ============================================================${RESET}\n"
    printf "${BOLD}${YELLOW}  WARNING: 'setup --internet' (Serveo) is DEPRECATED${RESET}\n"
    printf "${BOLD}${YELLOW}  ============================================================${RESET}\n"
    printf "${YELLOW}  Serveo's free tier does not route SSH traffic on its subdomains.${RESET}\n"
    printf "${YELLOW}  Any tunnel this flag sets up WILL NOT carry real SSH — connecting${RESET}\n"
    printf "${YELLOW}  to <subdomain>.serveo.net:22 hits Serveo's own sshd, not your machine.${RESET}\n"
    printf "\n"
    printf "${YELLOW}  Use Tailscale instead. See the 'Internet connectivity (Tailscale)'${RESET}\n"
    printf "${YELLOW}  section of the README:${RESET}\n"
    printf "${YELLOW}    https://github.com/EthanSK/agent-bridge#internet-connectivity-tailscale${RESET}\n"
    printf "\n"
    printf "${YELLOW}  Continuing anyway since --internet was passed. This is only useful${RESET}\n"
    printf "${YELLOW}  for tearing down a previously-installed Serveo LaunchAgent or${RESET}\n"
    printf "${YELLOW}  experimenting with a paid Serveo tier.${RESET}\n"
    printf "${BOLD}${YELLOW}  ============================================================${RESET}\n"
    printf "\n"
    printf "${BOLD}  4. Internet Tunnel (Serveo, DEPRECATED)${RESET}\n"

    case "$tunnel_provider" in
      serveo)
        # Pick a subdomain based on machine name
        local raw_sub
        raw_sub="$(printf '%s' "$machine_name" | tr '[:upper:]' '[:lower:]' | tr ' _' '-' | tr -cd 'a-z0-9-')"
        local subdomain="${raw_sub}"

        # Test if subdomain is available by attempting a quick tunnel.
        #
        # Detection note: for SSH port-22 reverse tunnels, serveo.net emits NO
        # "Forwarding" banner on stdout/stderr — that banner is only printed
        # for HTTP tunnels. We therefore probe with `ssh -v` and look for the
        # SSH client's own debug line:
        #   "debug1: remote forward success for: listen <sub>:22, connect ..."
        # which is the authoritative signal that serveo accepted the forward.
        # Failure signals on serveo: auth timeout, "remote forward failure",
        # or process exit with no success line.
        dim "Trying subdomain: ${subdomain}.serveo.net ..."
        local tunnel_log
        tunnel_log="$(mktemp)"
        ssh -v -o StrictHostKeyChecking=no -o ServerAliveInterval=60 -o ServerAliveCountMax=3 \
          -R "${subdomain}:22:localhost:${port}" serveo.net -N > "$tunnel_log" 2>&1 &
        local test_pid=$!

        # Wait for serveo to confirm or reject (up to 15 seconds)
        local waited=0 tunnel_ok=0
        while [ "$waited" -lt 15 ]; do
          if ! kill -0 "$test_pid" 2>/dev/null; then
            # Process exited — likely auth failure, subdomain taken, or serveo down
            break
          fi
          # Authoritative success: ssh debug says the forward was accepted
          if grep -q "remote forward success for: listen ${subdomain}:" "$tunnel_log" 2>/dev/null; then
            tunnel_ok=1
            break
          fi
          # Authoritative failure signals
          if grep -qiE "remote forward failure|already in use|Authentication failed|Connection refused" "$tunnel_log" 2>/dev/null; then
            break
          fi
          sleep 1
          waited=$((waited + 1))
        done

        # If subdomain taken, try with random suffix
        if [ "$tunnel_ok" = "0" ]; then
          kill "$test_pid" 2>/dev/null || true
          wait "$test_pid" 2>/dev/null || true
          local suffix
          suffix="$(head -c 3 /dev/urandom | xxd -p | head -c 4)"
          subdomain="${raw_sub}-${suffix}"
          warn "Subdomain taken or unavailable, trying: ${subdomain}.serveo.net ..."

          : > "$tunnel_log"
          ssh -v -o StrictHostKeyChecking=no -o ServerAliveInterval=60 -o ServerAliveCountMax=3 \
            -R "${subdomain}:22:localhost:${port}" serveo.net -N > "$tunnel_log" 2>&1 &
          test_pid=$!

          waited=0
          while [ "$waited" -lt 15 ]; do
            if ! kill -0 "$test_pid" 2>/dev/null; then
              break
            fi
            if grep -q "remote forward success for: listen ${subdomain}:" "$tunnel_log" 2>/dev/null; then
              tunnel_ok=1
              break
            fi
            if grep -qiE "remote forward failure|already in use|Authentication failed|Connection refused" "$tunnel_log" 2>/dev/null; then
              break
            fi
            sleep 1
            waited=$((waited + 1))
          done
        fi

        # Kill the test tunnel — the LaunchAgent will run the persistent one
        kill "$test_pid" 2>/dev/null || true
        wait "$test_pid" 2>/dev/null || true
        rm -f "$tunnel_log" 2>/dev/null

        if [ "$tunnel_ok" = "1" ]; then
          ok "Subdomain ${subdomain}.serveo.net is available!"
          printf '\n'

          # Save tunnel config
          ensure_config_dir
          cat > "$TUNNEL_CONFIG_FILE" <<TJSON
{
  "subdomain": "${subdomain}",
  "port": ${port},
  "enabled": true
}
TJSON
          chmod 600 "$TUNNEL_CONFIG_FILE"
          ok "Tunnel config saved to $TUNNEL_CONFIG_FILE"

          # Install LaunchAgent for persistence (macOS)
          if is_macos; then
            dim "Installing LaunchAgent for persistent tunnel..."
            mkdir -p "$HOME/Library/LaunchAgents"
            cat > "$LAUNCH_AGENT_PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LAUNCH_AGENT_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/ssh</string>
    <string>-o</string>
    <string>StrictHostKeyChecking=no</string>
    <string>-o</string>
    <string>ServerAliveInterval=60</string>
    <string>-o</string>
    <string>ServerAliveCountMax=3</string>
    <string>-o</string>
    <string>ExitOnForwardFailure=yes</string>
    <string>-R</string>
    <string>${subdomain}:22:localhost:${port}</string>
    <string>serveo.net</string>
    <string>-N</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>StandardOutPath</key>
  <string>${CONFIG_DIR}/logs/tunnel.log</string>
  <key>StandardErrorPath</key>
  <string>${CONFIG_DIR}/logs/tunnel.log</string>
</dict>
</plist>
PLIST
            # Ensure logs dir exists
            mkdir -p "$CONFIG_DIR/logs"

            # Unload any existing agent first
            launchctl unload "$LAUNCH_AGENT_PLIST" 2>/dev/null || true
            if launchctl load "$LAUNCH_AGENT_PLIST"; then
              ok "LaunchAgent installed and loaded (auto-restarts on boot)."
            else
              warn "LaunchAgent plist written but 'launchctl load' failed."
              warn "Try manually: launchctl load $LAUNCH_AGENT_PLIST"
            fi
          else
            warn "Not macOS — skipping LaunchAgent. Start the tunnel manually:"
            dim "  ssh -o StrictHostKeyChecking=no -o ServerAliveInterval=60 -o ServerAliveCountMax=3 -R ${subdomain}:22:localhost:${port} serveo.net -N &"
          fi

          printf '\n'
          printf "${BOLD}${YELLOW}  Tunnel accepted by Serveo — but this subdomain does NOT route SSH.${RESET}\n"
          printf "${YELLOW}  Connecting to ${subdomain}.serveo.net:22 will hit Serveo's own sshd,${RESET}\n"
          printf "${YELLOW}  not your machine. Do NOT set this as internet_host — it won't work.${RESET}\n"
          printf '\n'
          printf "${YELLOW}  Subdomain: %s.serveo.net (tunnel up, SSH not routed)${RESET}\n" "$subdomain"
          printf "${YELLOW}  Use Tailscale instead — see README 'Internet connectivity (Tailscale)':${RESET}\n"
          printf "${YELLOW}    https://github.com/EthanSK/agent-bridge#internet-connectivity-tailscale${RESET}\n"
          printf '\n'
          dim "To tear down this tunnel: agent-bridge setup --internet --stop"
          printf '\n'
        else
          warn "Could not establish Serveo tunnel. serveo.net may be down."
          printf '\n'
          printf "${BOLD}  Manual alternatives:${RESET}\n"
          dim "  1. Port forward $port on your router to this machine's local IP ($primary_ip)"
          dim "  2. Use Tailscale (https://tailscale.com) for a private tunnel"
          dim "  3. Use ngrok: ngrok tcp $port"
          printf '\n'
        fi
        ;;
      *)
        die "Unknown tunnel provider: $tunnel_provider. Supported: serveo"
        ;;
    esac
  fi

  # Manual pairing string (includes public key — no password needed)
  printf "${BOLD}${CYAN}  Pairing command (run on the other machine):${RESET}\n"
  printf '\n'
  printf "${DIM}  agent-bridge pair \\\\${RESET}\n"
  printf "${DIM}    --name \"%s\" \\\\${RESET}\n" "$machine_name"
  printf "${DIM}    --host \"%s\" \\\\${RESET}\n" "$primary_ip"
  printf "${DIM}    --port %s \\\\${RESET}\n" "$port"
  printf "${DIM}    --user \"%s\" \\\\${RESET}\n" "$user"
  printf "${DIM}    --token \"%s\" \\\\${RESET}\n" "$pairing_token"
  printf "${DIM}    --pubkey \"%s\"${RESET}\n" "$pub_key"
  printf '\n'

  printf "${BOLD}  Fingerprint:      ${DIM}%s${RESET}\n" "$fingerprint"
  printf '\n'
  dim "No password required. The other machine adds your public key to its"
  dim "authorized_keys, authorizing this machine to SSH in."
  printf '\n'

  # Step: Update AI harness instruction files
  printf "${BOLD}  4. AI Harness Instructions${RESET}\n"
  update_harness_instructions
  printf '\n'

  ok "Setup complete. This screen will stay visible."
  dim "Press Ctrl+C to close."
  printf '\n'

  # Keep process alive so user can photograph
  # Clean up tunnel on exit
  cleanup() {
    [ -n "$TUNNEL_PID" ] && kill "$TUNNEL_PID" 2>/dev/null
    printf "\n"
  }
  trap cleanup EXIT INT TERM
  while true; do sleep 86400; done
}

