cmd_connect() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_connect_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge connect <machine>"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  local host user port keypath internet_host internet_port
  host="$(cfg_get "$machine_name" host)"
  user="$(cfg_get "$machine_name" user)"
  port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"
  internet_host="$(cfg_get "$machine_name" internet_host 2>/dev/null || true)"
  internet_port="$(cfg_get "$machine_name" internet_port 2>/dev/null || printf '22')"

  local has_fallback=0
  [ -n "$internet_host" ] && has_fallback=1

  printf '\n'
  printf "${CYAN}  Connecting to ${BOLD}%s${RESET}${CYAN} (%s@%s)...${RESET}\n" "$machine_name" "$user" "$host"
  printf '\n'

  local lan_timeout=10
  [ "$has_fallback" = "1" ] && lan_timeout=3

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=${lan_timeout}" "-p" "$port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath")
  fi
  args+=("${user}@${host}")

  local exit_code=0
  ssh "${args[@]}" || exit_code=$?

  # Only fall back on SSH connection failure (exit 255), not normal session exit.
  # Exit code 255 means SSH itself failed to connect.
  if [ "$exit_code" -eq 255 ] && [ "$has_fallback" = "1" ]; then
    printf '\n'
    dim "LAN connection failed (SSH exit 255), trying internet fallback (${internet_host}:${internet_port})..."
    printf '\n'
    local inet_args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=10" "-p" "$internet_port")
    if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
      inet_args+=("-i" "$keypath")
    fi
    inet_args+=("${user}@${internet_host}")
    exit_code=0
    ssh "${inet_args[@]}" || exit_code=$?
  fi

  printf '\n'
  if [ "$exit_code" -eq 0 ]; then
    dim "Connection closed."
  else
    printf "${YELLOW}  SSH exited with code %d.${RESET}\n" "$exit_code"
  fi
}

cmd_connect_help() {
  printf 'Usage: agent-bridge connect <machine>\n\n'
  printf 'Open an interactive SSH session to a paired machine.\n'
}

cmd_run() {
  local machine_name="" command=""

  # Parse args — machine and command are positional
  while [ $# -gt 0 ]; do
    case "$1" in
      --agent|--claude|--codex)
        die "The $1 flag was removed in agent-bridge 3.0.0. 'agent-bridge run' is a plain remote-shell utility only — it does NOT spawn agents. To talk to the running agent on another machine, use the channel plugin's bridge_send_message MCP tool."
        ;;
      --help|-h) cmd_run_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)
        if [ -z "$machine_name" ]; then
          machine_name="$1"
        elif [ -z "$command" ]; then
          command="$1"
        else
          die "Unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge run <machine> \"shell command\""
  [ -z "$command" ] && die "Command required. Usage: agent-bridge run <machine> \"shell command\""

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  local host user port keypath internet_host internet_port
  host="$(cfg_get "$machine_name" host)"
  user="$(cfg_get "$machine_name" user)"
  port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"
  internet_host="$(cfg_get "$machine_name" internet_host 2>/dev/null || true)"
  internet_port="$(cfg_get "$machine_name" internet_port 2>/dev/null || printf '22')"

  local has_fallback=0
  [ -n "$internet_host" ] && has_fallback=1

  local lan_timeout=10
  [ "$has_fallback" = "1" ] && lan_timeout=3

  printf "${DIM}  Running command on %s...${RESET}\n" "$machine_name"

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=${lan_timeout}" "-p" "$port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath")
  fi
  args+=("${user}@${host}" "$command")

  local exit_code=0
  ssh "${args[@]}" || exit_code=$?

  # Only fall back on SSH connection failure (exit 255), not remote command failures.
  # Exit code 255 means SSH itself failed (connection refused, timeout, auth failure).
  if [ "$exit_code" -eq 255 ] && [ "$has_fallback" = "1" ]; then
    dim "LAN connection failed (SSH exit 255), trying internet fallback (${internet_host}:${internet_port})..."
    local inet_args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=10" "-p" "$internet_port")
    if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
      inet_args+=("-i" "$keypath")
    fi
    inet_args+=("${user}@${internet_host}" "$command")
    exit_code=0
    ssh "${inet_args[@]}" || exit_code=$?
  fi

  printf '\n'
  if [ "$exit_code" -eq 0 ]; then
    ok "command completed on $machine_name (exit 0)"
  else
    printf "${YELLOW}  command on %s exited with code %d.${RESET}\n" "$machine_name" "$exit_code"
  fi

  exit "$exit_code"
}

cmd_run_help() {
  printf 'Usage: agent-bridge run <machine> "shell command"\n\n'
  printf 'Run a PLAIN shell command on a paired machine over SSH.\n\n'
  printf 'This is a diagnostic utility — use it for things like `git status`,\n'
  printf '`ls ~/Projects`, `ps aux`, checking file paths, tailing logs, etc.\n\n'
  printf 'To talk to the RUNNING agent on another paired machine, use the\n'
  printf 'agent-bridge channel plugin and its `bridge_send_message` MCP tool.\n'
  printf 'That is the ONLY supported agent-to-agent communication path.\n\n'
  printf 'The `--claude`, `--codex`, and `--agent` flags were REMOVED in\n'
  printf 'agent-bridge 3.0.0. They spawned a new non-interactive agent session\n'
  printf 'on the remote machine (e.g. `claude --print`), which is exactly what\n'
  printf 'this project is NOT meant to encourage.\n\n'
  printf 'Options:\n'
  printf '  -h, --help     Show this help\n'
}

cmd_list() {
  printf '\n'
  printf "${BOLD}${CYAN}  agent-bridge list${RESET}\n"
  printf '\n'

  local names
  names="$(cfg_list_names)"

  if [ -z "$names" ]; then
    dim "No paired machines."
    printf '\n'
    dim "To pair a machine:"
    dim "  1. Run 'agent-bridge setup' on the other machine"
    dim "  2. Send a photo of the pairing screen to this machine's Claude"
    dim "  3. Run 'agent-bridge pair' here with the details"
    printf '\n'
    return
  fi

  local count=0
  while IFS= read -r name; do
    [ -z "$name" ] && continue
    count=$((count + 1))
    local host user port keypath paired_at
    host="$(cfg_get "$name" host 2>/dev/null || printf 'unknown')"
    user="$(cfg_get "$name" user 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$name" port 2>/dev/null || printf '22')"
    keypath="$(cfg_get "$name" key 2>/dev/null || printf '(system default)')"
    paired_at="$(cfg_get "$name" paired_at 2>/dev/null || true)"

    local ihost iport
    ihost="$(cfg_get "$name" internet_host 2>/dev/null || true)"
    iport="$(cfg_get "$name" internet_port 2>/dev/null || true)"

    printf "${BOLD}  %s${RESET}\n" "$name"
    printf "${DIM}    Host:       %s${RESET}\n" "$host"
    printf "${DIM}    Port:       %s${RESET}\n" "$port"
    if [ -n "$ihost" ]; then
      printf "${DIM}    Internet:   %s:%s${RESET}\n" "$ihost" "${iport:-22}"
    fi
    printf "${DIM}    User:       %s${RESET}\n" "$user"
    printf "${DIM}    Key:        %s${RESET}\n" "$keypath"
    if [ -n "$paired_at" ]; then
      printf "${DIM}    Paired:     %s${RESET}\n" "$paired_at"
    fi
    printf '\n'
  done <<< "$names"

  dim "$count machine$([ "$count" -ne 1 ] && printf 's') paired."
  printf '\n'
}

cmd_status() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_status_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  printf '\n'
  printf "${BOLD}${CYAN}  agent-bridge status${RESET}\n"
  printf '\n'

  check_machine() {
    local name="$1"
    local host user port keypath internet_host internet_port
    host="$(cfg_get "$name" host 2>/dev/null || printf 'unknown')"
    user="$(cfg_get "$name" user 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$name" port 2>/dev/null || printf '22')"
    keypath="$(cfg_get "$name" key 2>/dev/null || true)"
    keypath="${keypath/#\~/$HOME}"
    internet_host="$(cfg_get "$name" internet_host 2>/dev/null || true)"
    internet_port="$(cfg_get "$name" internet_port 2>/dev/null || printf '22')"

    local has_fallback=0
    [ -n "$internet_host" ] && has_fallback=1

    local lan_timeout=5
    [ "$has_fallback" = "1" ] && lan_timeout=3

    local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=${lan_timeout}" "-p" "$port")
    if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
      args+=("-i" "$keypath")
    fi
    args+=("${user}@${host}" "echo ok")

    local start_time
    if is_macos; then
      start_time=$(perl -MTime::HiRes=time -e 'printf "%.0f\n", time*1000')
    else
      start_time=$(($(date +%s%N) / 1000000))
    fi

    local lan_exit=0
    ssh "${args[@]}" >/dev/null 2>&1 || lan_exit=$?

    if [ "$lan_exit" -eq 0 ]; then
      local end_time
      if is_macos; then
        end_time=$(perl -MTime::HiRes=time -e 'printf "%.0f\n", time*1000')
      else
        end_time=$(($(date +%s%N) / 1000000))
      fi
      local latency=$((end_time - start_time))
      printf "${GREEN}  %s${RESET}${DIM} (%s@%s:%s via LAN) -- %dms${RESET}\n" "$name" "$user" "$host" "$port" "$latency"
      return 0
    fi

    # Only try internet fallback on SSH connection failure (exit 255)
    if [ "$lan_exit" -eq 255 ] && [ "$has_fallback" = "1" ]; then
      local inet_args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=10" "-p" "$internet_port")
      if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
        inet_args+=("-i" "$keypath")
      fi
      inet_args+=("${user}@${internet_host}" "echo ok")

      local inet_start
      if is_macos; then
        inet_start=$(perl -MTime::HiRes=time -e 'printf "%.0f\n", time*1000')
      else
        inet_start=$(($(date +%s%N) / 1000000))
      fi

      if ssh "${inet_args[@]}" >/dev/null 2>&1; then
        local inet_end
        if is_macos; then
          inet_end=$(perl -MTime::HiRes=time -e 'printf "%.0f\n", time*1000')
        else
          inet_end=$(($(date +%s%N) / 1000000))
        fi
        local inet_latency=$((inet_end - inet_start))
        printf "${GREEN}  %s${RESET}${DIM} (%s@%s:%s via internet) -- %dms${RESET}\n" "$name" "$user" "$internet_host" "$internet_port" "$inet_latency"
        return 0
      fi

      printf "${RED}  %s${RESET}${DIM} -- unreachable on both LAN (%s) and internet (%s)${RESET}\n" "$name" "$host" "$internet_host"
      return 1
    fi

    printf "${RED}  %s${RESET}${DIM} (%s) -- unreachable${RESET}\n" "$name" "$host"
    return 1
  }

  if [ -n "$machine_name" ]; then
    if ! cfg_exists "$machine_name"; then
      die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
    fi
    check_machine "$machine_name"
  else
    local names
    names="$(cfg_list_names)"

    if [ -z "$names" ]; then
      dim "No paired machines."
      dim "Run 'agent-bridge setup' on each machine, then 'agent-bridge pair' to connect them."
      printf '\n'
      return
    fi

    local total=0 reachable=0
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      total=$((total + 1))
      if check_machine "$name"; then
        reachable=$((reachable + 1))
      fi
    done <<< "$names"

    printf '\n'
    dim "$reachable/$total machines reachable."
  fi

  printf '\n'
}

cmd_status_help() {
  printf 'Usage: agent-bridge status [machine]\n\n'
  printf 'Check if paired machine(s) are reachable.\n'
  printf 'Omit machine name to check all.\n'
}

cmd_unpair() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_unpair_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge unpair <machine>"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  # Try to remove the key file
  local keypath
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ] && [ -f "$keypath" ]; then
    rm -f "$keypath" 2>/dev/null && dim "Removed key: $keypath" || warn "Could not remove key at $keypath"
    # Also remove .pub if it exists
    [ -f "${keypath}.pub" ] && rm -f "${keypath}.pub" 2>/dev/null
  fi

  cfg_remove "$machine_name"
  printf '\n'
  ok "Unpaired \"$machine_name\"."
  printf '\n'
}

cmd_unpair_help() {
  printf 'Usage: agent-bridge unpair <machine>\n\n'
  printf 'Remove a paired machine and its SSH key.\n'
}

# -- config -------------------------------------------------------------------
cmd_config() {
  local machine_name=""
  local internet_host="" internet_port=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --internet-host)
        [ $# -lt 2 ] && die "--internet-host requires a value."
        internet_host="$2"; shift 2 ;;
      --internet-port)
        [ $# -lt 2 ] && die "--internet-port requires a value."
        internet_port="$2"; shift 2 ;;
      --help|-h)        cmd_config_help; exit 0 ;;
      -*)               die "Unknown option: $1. Use --help for usage." ;;
      *)
        if [ -z "$machine_name" ]; then
          machine_name="$1"
        else
          die "Unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge config <machine> --internet-host <host>"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  if [ -z "$internet_host" ] && [ -z "$internet_port" ]; then
    # Show current config
    local host port user ihost iport
    host="$(cfg_get "$machine_name" host 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
    user="$(cfg_get "$machine_name" user 2>/dev/null || printf 'unknown')"
    ihost="$(cfg_get "$machine_name" internet_host 2>/dev/null || true)"
    iport="$(cfg_get "$machine_name" internet_port 2>/dev/null || true)"

    printf '\n'
    printf "${BOLD}  %s${RESET}\n" "$machine_name"
    printf "${DIM}    host=%s${RESET}\n" "$host"
    printf "${DIM}    port=%s${RESET}\n" "$port"
    printf "${DIM}    user=%s${RESET}\n" "$user"
    if [ -n "$ihost" ]; then
      printf "${DIM}    internet_host=%s${RESET}\n" "$ihost"
    fi
    if [ -n "$iport" ]; then
      printf "${DIM}    internet_port=%s${RESET}\n" "$iport"
    fi
    printf '\n'
    return
  fi

  if [ -n "$internet_host" ]; then
    # Validate: no newlines, no brackets, no equals signs, no whitespace
    if printf '%s' "$internet_host" | grep -qE '[[:space:]\[\]=]|^$' 2>/dev/null; then
      die "Invalid internet_host: must not contain whitespace, brackets, or '=' characters."
    fi
    cfg_set "$machine_name" "internet_host" "$internet_host"
    ok "Set internet_host=$internet_host for $machine_name"
  fi

  if [ -n "$internet_port" ]; then
    # Validate: must be an integer 1-65535
    if ! [[ "$internet_port" =~ ^[0-9]+$ ]] || [ "$internet_port" -lt 1 ] || [ "$internet_port" -gt 65535 ]; then
      die "Invalid internet_port: must be an integer between 1 and 65535."
    fi
    cfg_set "$machine_name" "internet_port" "$internet_port"
    ok "Set internet_port=$internet_port for $machine_name"
  fi
  printf '\n'
}

cmd_config_help() {
  printf 'Usage: agent-bridge config <machine> [OPTIONS]\n\n'
  printf 'View or update configuration for a paired machine.\n\n'
  printf 'With no options, prints the current config for the machine.\n\n'
  printf 'Options:\n'
  printf '  --internet-host <host>   Set the internet-reachable hostname or IP.\n'
  printf '                           Recommended: a Tailscale 100.x.y.z address.\n'
  printf '                           See README section "Internet connectivity (Tailscale)".\n'
  printf '  --internet-port <port>   Set the internet-reachable SSH port (default: 22)\n'
  printf '  -h, --help               Show this help\n\n'
  printf 'Examples:\n'
  printf '  agent-bridge config MacBook-Pro\n'
  printf '  agent-bridge config MacBook-Pro --internet-host 100.126.23.87\n'
  printf '  agent-bridge config MacBook-Pro --internet-host 100.126.23.87 --internet-port 22\n'
}

cmd_help() {
  printf '\n'
  printf "${BOLD}agent-bridge${RESET} v%s\n" "$VERSION"
  printf 'Bridge AI coding agents across machines.\n'
  printf 'Pure bash. Zero dependencies.\n'
  printf '\n'
  printf "${BOLD}Usage:${RESET}\n"
  printf '  agent-bridge <command> [options]\n'
  printf '\n'
  printf "${BOLD}Commands:${RESET}\n"
  printf '  setup              Enable SSH, generate keys, show pairing screen\n'
  printf '  setup --internet   [DEPRECATED] Legacy Serveo tunnel (does not route SSH).\n'
  printf '                     Use Tailscale instead — see README.\n'
  printf '  setup --internet --stop\n'
  printf '                     Tear down an existing legacy Serveo tunnel + LaunchAgent\n'
  printf '  pair               Pair with another machine (interactive or flags)\n'
  printf '  config <machine>   View or update machine config (--internet-host, --internet-port)\n'
  printf '  connect <machine>  Open an interactive SSH session\n'
  printf '  run <machine> "cmd"  Run a plain shell command on a paired machine (diagnostics only)\n'
  printf '  list               List all paired machines\n'
  printf '  status [machine]   Check reachability (tries LAN then internet fallback)\n'
  printf '  unpair <machine>   Remove a pairing\n'
  printf '  version            Show version\n'
  printf '  help               Show this help\n'
  printf '\n'
  printf "${BOLD}Agent-to-agent communication:${RESET}\n"
  printf "  Talking to the RUNNING agent on another machine is done via the\n"
  printf "  Claude Code channel plugin and its bridge_send_message MCP tool.\n"
  printf "  The CLI does NOT wrap or spawn agents — 'run' is shell-only.\n"
  printf '\n'
  printf "${BOLD}Examples:${RESET}\n"
  printf '  agent-bridge setup --name MacBook-Pro\n'
  printf '  agent-bridge pair --host 192.168.1.50 --user ethan --name MacBook-Pro --pubkey "ssh-ed25519 AAAA..."\n'
  printf '  agent-bridge run MacBook-Pro "ls -la ~/Projects"\n'
  printf '  agent-bridge run MacBook-Pro "cd ~/Projects/myapp && git pull"\n'
  printf '  agent-bridge connect MacBook-Pro\n'
  printf '\n'
  printf 'https://github.com/EthanSK/agent-bridge\n'
  printf '\n'
}

cmd_version() {
  printf 'agent-bridge %s\n' "$VERSION"
}

# -- Main dispatch ------------------------------------------------------------
main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    setup)    cmd_setup "$@" ;;
    pair)     cmd_pair "$@" ;;
    config)   cmd_config "$@" ;;
    connect)  cmd_connect "$@" ;;
    run)      cmd_run "$@" ;;
    list)     cmd_list "$@" ;;
    status)   cmd_status "$@" ;;
    unpair)   cmd_unpair "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h)       cmd_help ;;
    *)        die "Unknown command: $cmd. Run 'agent-bridge help' for usage." ;;
  esac
}

main "$@"
