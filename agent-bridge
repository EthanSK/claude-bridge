#!/usr/bin/env bash
set -euo pipefail

# agent-bridge — Bridge AI coding agents across machines.
# Pure bash. Zero dependencies. Works on any Mac/Linux out of the box.
# https://github.com/EthanSK/agent-bridge
#
# Previously known as claude-bridge.

INVOKED_AS="$(basename "$0")"

VERSION="3.0.0"

# -- Colours (ANSI) ----------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# -- Deprecation notice -------------------------------------------------------
if [ "$INVOKED_AS" = "claude-bridge" ]; then
  printf '\033[0;33m  [deprecated] "claude-bridge" has been renamed to "agent-bridge". Please update your scripts.\033[0m\n' >&2
fi

# -- Paths --------------------------------------------------------------------
CONFIG_DIR="$HOME/.agent-bridge"
CONFIG_FILE="$CONFIG_DIR/config"
KEYS_DIR="$CONFIG_DIR/keys"

# Migrate from old config dir if it exists and new one doesn't
if [ ! -d "$CONFIG_DIR" ] && [ -d "$HOME/.claude-bridge" ]; then
  mv "$HOME/.claude-bridge" "$CONFIG_DIR"
fi

# -- Helpers ------------------------------------------------------------------
die()  { printf "${RED}  Error: %s${RESET}\n" "$1" >&2; exit 1; }
info() { printf "${CYAN}%s${RESET}\n" "$1"; }
ok()   { printf "${GREEN}  [ok] %s${RESET}\n" "$1"; }
warn() { printf "${YELLOW}  %s${RESET}\n" "$1"; }
dim()  { printf "${DIM}  %s${RESET}\n" "$1"; }

ensure_config_dir() {
  [ -d "$CONFIG_DIR" ] || mkdir -p "$CONFIG_DIR" && chmod 700 "$CONFIG_DIR"
  [ -d "$KEYS_DIR" ]   || mkdir -p "$KEYS_DIR"   && chmod 700 "$KEYS_DIR"
  [ -f "$CONFIG_FILE" ] || touch "$CONFIG_FILE"   && chmod 600 "$CONFIG_FILE"
}

# -- INI-style config parser --------------------------------------------------
# Config format:
#   [MacBook-Pro]
#   host=MacBookPro.local
#   user=ethansk
#   port=22
#   key=~/.agent-bridge/keys/MacBook-Pro
#   paired_at=2026-04-09T12:00:00

# Get a value for a machine: cfg_get <machine> <key>
cfg_get() {
  local machine="$1" key="$2"
  if [ ! -f "$CONFIG_FILE" ]; then
    return 1
  fi
  local in_section=0
  while IFS= read -r line || [ -n "$line" ]; do
    # Strip carriage returns
    line="${line%$'\r'}"
    # Check for section header (case-insensitive match)
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$(printf '%s' "$section" | tr '[:upper:]' '[:lower:]')" = "$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')" ]; then
        in_section=1
      else
        in_section=0
      fi
      continue
    fi
    if [ "$in_section" = "1" ] && [[ "$line" =~ ^${key}=(.*)$ ]]; then
      printf '%s' "${BASH_REMATCH[1]}"
      return 0
    fi
  done < "$CONFIG_FILE"
  return 1
}

# Check if a machine exists (case-insensitive)
cfg_exists() {
  local machine="$1"
  local lower_machine
  lower_machine="$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')"
  if [ ! -f "$CONFIG_FILE" ]; then
    return 1
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$(printf '%s' "$section" | tr '[:upper:]' '[:lower:]')" = "$lower_machine" ]; then
        return 0
      fi
    fi
  done < "$CONFIG_FILE"
  return 1
}

# Get the exact section name (preserving original case)
cfg_real_name() {
  local machine="$1"
  local lower_machine
  lower_machine="$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')"
  if [ ! -f "$CONFIG_FILE" ]; then
    return 1
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$(printf '%s' "$section" | tr '[:upper:]' '[:lower:]')" = "$lower_machine" ]; then
        printf '%s' "$section"
        return 0
      fi
    fi
  done < "$CONFIG_FILE"
  return 1
}

# Save a machine config (overwrites if exists)
cfg_save() {
  local machine="$1" host="$2" user="$3" port="$4" keypath="$5"
  ensure_config_dir

  # Remove existing section first
  cfg_remove "$machine" 2>/dev/null || true

  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # Expand ~ in keypath
  keypath="${keypath/#\~/$HOME}"

  {
    printf '[%s]\n' "$machine"
    printf 'host=%s\n' "$host"
    printf 'user=%s\n' "$user"
    printf 'port=%s\n' "$port"
    printf 'key=%s\n' "$keypath"
    printf 'paired_at=%s\n' "$ts"
    printf '\n'
  } >> "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
}

# Remove a machine section
cfg_remove() {
  local machine="$1"
  if ! cfg_exists "$machine"; then
    return 1
  fi
  local real_name
  real_name="$(cfg_real_name "$machine")"
  local tmpfile
  tmpfile="$(mktemp)"
  local in_section=0
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$section" = "$real_name" ]; then
        in_section=1
        continue
      else
        in_section=0
      fi
    fi
    if [ "$in_section" = "1" ]; then
      # Skip lines in the removed section
      continue
    fi
    printf '%s\n' "$line"
  done < "$CONFIG_FILE" > "$tmpfile"
  mv "$tmpfile" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
}

# List all machine names
cfg_list_names() {
  if [ ! -f "$CONFIG_FILE" ]; then
    return
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      printf '%s\n' "${BASH_REMATCH[1]}"
    fi
  done < "$CONFIG_FILE"
}

# -- Network helpers ----------------------------------------------------------
get_local_ip() {
  if command -v ipconfig >/dev/null 2>&1; then
    # macOS
    local ip
    ip="$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || true)"
    if [ -n "$ip" ]; then
      printf '%s' "$ip"
      return
    fi
  fi
  # Linux / fallback
  if command -v hostname >/dev/null 2>&1; then
    local ip
    ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
    if [ -n "$ip" ]; then
      printf '%s' "$ip"
      return
    fi
  fi
  # Last resort
  if command -v ifconfig >/dev/null 2>&1; then
    local ip
    ip="$(ifconfig 2>/dev/null | grep 'inet ' | grep -v '127.0.0.1' | head -1 | awk '{print $2}')"
    if [ -n "$ip" ]; then
      printf '%s' "$ip"
      return
    fi
  fi
  printf 'unknown'
}

get_public_ip() {
  curl -s --max-time 3 ifconfig.me 2>/dev/null || printf 'unavailable'
}

get_hostname() {
  hostname 2>/dev/null || printf 'unknown'
}

get_machine_name() {
  local h
  h="$(get_hostname)"
  # Strip .local suffix
  printf '%s' "${h%.local}"
}

get_username() {
  whoami 2>/dev/null || printf '%s' "$USER"
}

generate_pairing_token() {
  local hex
  hex="$(head -c 4 /dev/urandom | xxd -p | head -c 6)"
  printf 'bridge-%s' "$hex"
}

is_macos() {
  [ "$(uname -s)" = "Darwin" ]
}

# -- SSH helpers --------------------------------------------------------------
ssh_build_args() {
  local machine="$1"
  local host user port keypath
  host="$(cfg_get "$machine" host)" || die "Machine \"$machine\" not found."
  user="$(cfg_get "$machine" user)" || die "No user for \"$machine\"."
  port="$(cfg_get "$machine" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine" key 2>/dev/null || true)"

  # Expand ~ in keypath
  keypath="${keypath/#\~/$HOME}"

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-p" "$port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath")
  fi
  args+=("${user}@${host}")

  printf '%s\n' "${args[@]}"
}

# -- Harness instruction files ------------------------------------------------
# After setup/pair, append agent-bridge instructions to detected AI harness
# config files (CLAUDE.md, AGENTS.md, GEMINI.md) so every new session knows
# about the bridge.

HARNESS_MARKER_START="<!-- agent-bridge:start -->"
HARNESS_MARKER_END="<!-- agent-bridge:end -->"

harness_instruction_block() {
  cat <<'BLOCK'
<!-- agent-bridge:start -->
## Agent Bridge

This machine has agent-bridge installed for cross-machine communication.

Paired machines (check with `agent-bridge list`):
- Run `agent-bridge status` to check which machines are reachable
- Run `agent-bridge run <machine> "command"` to execute a plain shell command remotely (diagnostics only — e.g. `git status`, `ls`, `ps aux`)
- Run `agent-bridge connect <machine>` for interactive SSH

To talk to the RUNNING agent on another paired machine, use the channel plugin's
`bridge_send_message` MCP tool. This is the ONLY supported way to communicate
agent-to-agent. `agent-bridge run` does NOT invoke a remote agent — it is a plain
remote-shell utility. There are no `--claude` / `--codex` / `--agent` flags.

Config: `~/.agent-bridge/config` | Keys: `~/.agent-bridge/keys/`

If a paired machine is unreachable, check if it's powered on and SSH (Remote Login) is enabled.
<!-- agent-bridge:end -->
BLOCK
}

# Update a single harness instruction file. Idempotent: replaces existing block
# or appends if not present.
# Usage: harness_update_file <filepath>
harness_update_file() {
  local filepath="$1"
  local block
  block="$(harness_instruction_block)"

  if [ ! -f "$filepath" ]; then
    # File doesn't exist — skip (we don't create files for harnesses that aren't installed)
    return 0
  fi

  if grep -qF "$HARNESS_MARKER_START" "$filepath" 2>/dev/null; then
    # Replace existing block between markers
    local tmpfile
    tmpfile="$(mktemp)"
    local in_block=0
    while IFS= read -r line || [ -n "$line" ]; do
      if [ "$line" = "$HARNESS_MARKER_START" ]; then
        in_block=1
        printf '%s\n' "$block" >> "$tmpfile"
        continue
      fi
      if [ "$in_block" = "1" ]; then
        if [ "$line" = "$HARNESS_MARKER_END" ]; then
          in_block=0
        fi
        continue
      fi
      printf '%s\n' "$line" >> "$tmpfile"
    done < "$filepath"
    mv "$tmpfile" "$filepath"
  else
    # Append block to end of file
    printf '\n%s\n' "$block" >> "$filepath"
  fi
}

# Detect installed harnesses and update their instruction files.
update_harness_instructions() {
  local updated=0

  # Claude Code: ~/.claude/CLAUDE.md
  if [ -f "$HOME/.claude/CLAUDE.md" ]; then
    harness_update_file "$HOME/.claude/CLAUDE.md"
    ok "Updated ~/.claude/CLAUDE.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  # Codex: ~/.codex/AGENTS.md
  if [ -f "$HOME/.codex/AGENTS.md" ]; then
    harness_update_file "$HOME/.codex/AGENTS.md"
    ok "Updated ~/.codex/AGENTS.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  # OpenClaw: ~/.openclaw/AGENTS.md
  if [ -f "$HOME/.openclaw/AGENTS.md" ]; then
    harness_update_file "$HOME/.openclaw/AGENTS.md"
    ok "Updated ~/.openclaw/AGENTS.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  # Gemini CLI: ~/.gemini/GEMINI.md
  if [ -f "$HOME/.gemini/GEMINI.md" ]; then
    harness_update_file "$HOME/.gemini/GEMINI.md"
    ok "Updated ~/.gemini/GEMINI.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  if [ "$updated" -eq 0 ]; then
    dim "No AI harness instruction files detected. Skipping."
  fi
}

# -- Commands -----------------------------------------------------------------

cmd_setup() {
  local machine_name="" port="22" internet=false tunnel_provider="serveo"
  TUNNEL_PID=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --name|-n)             machine_name="$2"; shift 2 ;;
      --port|-p)             port="$2"; shift 2 ;;
      --internet)            internet=true; shift ;;
      --tunnel-provider)     tunnel_provider="$2"; shift 2 ;;
      --help|-h)             cmd_setup_help; exit 0 ;;
      *)                     die "Unknown option: $1. Use --help for usage." ;;
    esac
  done

  [ -z "$machine_name" ] && machine_name="$(get_machine_name)"
  local user
  user="$(get_username)"
  local local_hostname
  local_hostname="$(get_hostname)"

  printf '\n'
  printf "${BOLD}${CYAN}  +----------------------------------------------+${RESET}\n"
  printf "${BOLD}${CYAN}  |         agent-bridge  .  setup                |${RESET}\n"
  printf "${BOLD}${CYAN}  +----------------------------------------------+${RESET}\n"
  printf '\n'

  # Step 1: Check/enable SSH
  printf "${BOLD}  1. SSH Server${RESET}\n"
  if is_macos; then
    local ssh_status
    ssh_status="$(sudo systemsetup -getremotelogin 2>/dev/null || printf 'unknown')"
    if printf '%s' "$ssh_status" | grep -qi 'on'; then
      ok "SSH (Remote Login) is already enabled."
    else
      dim "Enabling Remote Login (may require sudo)..."
      if sudo systemsetup -setremotelogin on 2>/dev/null; then
        ok "Remote Login enabled."
      else
        warn "Could not enable Remote Login automatically."
        warn "Enable it manually: System Settings > General > Sharing > Remote Login"
      fi
    fi
  else
    if systemctl is-active --quiet sshd 2>/dev/null || systemctl is-active --quiet ssh 2>/dev/null; then
      ok "SSH server is running."
    elif pgrep -x sshd >/dev/null 2>&1; then
      ok "SSH server is running."
    else
      warn "SSH server does not appear to be running."
      warn "Start it with: sudo systemctl start sshd"
    fi
  fi
  printf '\n'

  # Step 2: Generate key pair
  printf "${BOLD}  2. SSH Key Pair${RESET}\n"
  ensure_config_dir
  local key_path="$KEYS_DIR/agent-bridge_${machine_name}"
  local pub_key_path="${key_path}.pub"

  if [ -f "$key_path" ] && [ -f "$pub_key_path" ]; then
    dim "Using existing key pair."
  else
    dim "Generating SSH key pair..."
    ssh-keygen -t ed25519 -f "$key_path" -N "" -C "agent-bridge:${machine_name}" >/dev/null 2>&1
    chmod 600 "$key_path"
    ok "Key pair generated."
  fi

  # Save identity so pair/run/connect use the same key
  printf '%s' "$key_path" > "$CONFIG_DIR/.identity"

  # Add to authorized_keys
  local ssh_dir="$HOME/.ssh"
  local auth_keys="$ssh_dir/authorized_keys"
  [ -d "$ssh_dir" ] || mkdir -p "$ssh_dir" && chmod 700 "$ssh_dir"
  local pub_key
  pub_key="$(cat "$pub_key_path")"

  if [ -f "$auth_keys" ] && grep -qF "$pub_key" "$auth_keys" 2>/dev/null; then
    dim "Public key already in authorized_keys."
  else
    printf '%s\n' "$pub_key" >> "$auth_keys"
    chmod 600 "$auth_keys"
    ok "Public key added to authorized_keys."
  fi

  # Fingerprint
  local fingerprint
  fingerprint="$(ssh-keygen -lf "$pub_key_path" 2>/dev/null | awk '{print $2}' || printf 'unknown')"
  printf '\n'

  # Step 2b: Check Full Disk Access (macOS only)
  if is_macos; then
    printf "${BOLD}  2b. Full Disk Access${RESET}\n"
    # FDA cannot be reliably detected without root, and "ls ~/Desktop"
    # always succeeds locally. Just inform the user.
    warn "SSH sessions need Full Disk Access to reach Desktop, Documents, Downloads, etc."
    dim "Add /usr/sbin/sshd in System Settings > Privacy & Security > Full Disk Access."
    dim "Skip this if it's already there — you can always do it later."
    printf '\n'
  fi

  # Step 3: Get network info
  local primary_ip
  primary_ip="$(get_local_ip)"
  local public_ip
  public_ip="$(get_public_ip)"

  # Step 4: Generate pairing token
  printf "${BOLD}  3. Pairing Token${RESET}\n"
  local pairing_token
  pairing_token="$(generate_pairing_token)"
  ensure_config_dir
  printf '%s' "$pairing_token" > "$CONFIG_DIR/.pending-token"
  chmod 600 "$CONFIG_DIR/.pending-token"
  ok "One-time pairing token generated."
  printf '\n'

  # Step 5: Display pairing screen
  # Calculate box width — wide enough for the public key
  local pub_key_display="$pub_key"
  local pub_key_len=${#pub_key_display}
  local min_width=46
  local needed_width=$(( pub_key_len + 16 ))
  local box_width=$min_width
  [ "$needed_width" -gt "$box_width" ] && box_width=$needed_width
  local inner_width=$((box_width - 4))

  printf '\n'
  printf "${BOLD}${CYAN}"
  printf '  ╔'; printf '═%.0s' $(seq 1 $box_width); printf '╗\n'
  printf '  ║%*s%s%*s║\n' $(( (box_width - 21) / 2 )) "" "agent-bridge pairing" $(( (box_width - 20) / 2 )) ""
  printf '  ╠'; printf '═%.0s' $(seq 1 $box_width); printf '╣\n'
  printf "${RESET}"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Machine:${RESET}    %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$machine_name"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}User:${RESET}       %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$user"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Local:${RESET}      %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$local_hostname"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Local IP:${RESET}   %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$primary_ip"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Public IP:${RESET}  %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$public_ip"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Port:${RESET}       %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$port"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Token:${RESET}      ${YELLOW}${BOLD}%-*s${RESET}${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$pairing_token"
  printf "${BOLD}${CYAN}  ╠"; printf '═%.0s' $(seq 1 $box_width); printf "╣${RESET}\n"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Public Key:${RESET} %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$pub_key_display"
  printf "${BOLD}${CYAN}"
  printf '  ╚'; printf '═%.0s' $(seq 1 $box_width); printf '╝\n'
  printf "${RESET}"
  printf '\n'
  dim "Photograph this screen and send to Claude on your other machine."
  if [ "$internet" = false ]; then
    dim "For internet access, use --internet flag or Tailscale."
  fi
  printf '\n'

  # Internet tunnel
  if [ "$internet" = true ]; then
    printf "${BOLD}  4. Internet Tunnel${RESET}\n"
    local tunnel_address=""

    case "$tunnel_provider" in
      serveo)
        dim "Starting reverse SSH tunnel via serveo.net..."
        local tunnel_log
        tunnel_log="$(mktemp)"
        ssh -o StrictHostKeyChecking=no -o ServerAliveInterval=30 -R "0:localhost:${port}" serveo.net > "$tunnel_log" 2>&1 &
        TUNNEL_PID=$!

        # Wait for serveo to report the forwarding address (up to 10 seconds)
        local waited=0
        while [ "$waited" -lt 10 ]; do
          if [ -f "$tunnel_log" ]; then
            tunnel_address="$(grep -oE 'serveo\.net:[0-9]+' "$tunnel_log" 2>/dev/null | head -1 || true)"
            if [ -n "$tunnel_address" ]; then
              break
            fi
          fi
          sleep 1
          waited=$((waited + 1))
        done

        if [ -n "$tunnel_address" ]; then
          local tunnel_host="${tunnel_address%%:*}"
          local tunnel_port="${tunnel_address##*:}"
          ok "Tunnel active!"
          printf '\n'
          printf "${BOLD}${GREEN}  Internet access:${RESET}\n"
          printf "${BOLD}    Host: ${CYAN}%s${RESET}\n" "$tunnel_host"
          printf "${BOLD}    Port: ${CYAN}%s${RESET}\n" "$tunnel_port"
          printf '\n'
          printf "${DIM}  Remote pair command:${RESET}\n"
          printf "${DIM}    agent-bridge pair --name \"%s\" --host %s --port %s --user %s --token \"%s\" --pubkey \"%s\"${RESET}\n" \
            "$machine_name" "$tunnel_host" "$tunnel_port" "$user" "$pairing_token" "$pub_key"
          printf '\n'
        else
          warn "Tunnel may still be connecting. Check output below."
          warn "If serveo.net is unavailable, try port forwarding or Tailscale instead."
          if [ -n "$TUNNEL_PID" ] && kill -0 "$TUNNEL_PID" 2>/dev/null; then
            dim "Tunnel process running (PID $TUNNEL_PID)."
          else
            warn "Tunnel process exited. serveo.net may be down."
            TUNNEL_PID=""
          fi
          printf '\n'
        fi

        rm -f "$tunnel_log" 2>/dev/null
        ;;
      *)
        die "Unknown tunnel provider: $tunnel_provider. Supported: serveo"
        ;;
    esac

    if [ -z "$tunnel_address" ]; then
      printf "${BOLD}  Manual alternatives:${RESET}\n"
      dim "  1. Port forward $port on your router to this machine's local IP ($primary_ip)"
      dim "  2. Use Tailscale (https://tailscale.com) for a private tunnel"
      dim "  3. Use ngrok: ngrok tcp $port"
      printf '\n'
    fi
  fi

  # Manual pairing string (includes public key — no password needed)
  printf "${BOLD}${CYAN}  Pairing command (run on the other machine):${RESET}\n"
  printf '\n'
  printf "${DIM}  agent-bridge pair \\\\${RESET}\n"
  printf "${DIM}    --name \"%s\" \\\\${RESET}\n" "$machine_name"
  printf "${DIM}    --host \"%s\" \\\\${RESET}\n" "$primary_ip"
  printf "${DIM}    --port %s \\\\${RESET}\n" "$port"
  printf "${DIM}    --user \"%s\" \\\\${RESET}\n" "$user"
  printf "${DIM}    --token \"%s\" \\\\${RESET}\n" "$pairing_token"
  printf "${DIM}    --pubkey \"%s\"${RESET}\n" "$pub_key"
  printf '\n'

  printf "${BOLD}  Fingerprint:      ${DIM}%s${RESET}\n" "$fingerprint"
  printf '\n'
  dim "No password required. The other machine adds your public key to its"
  dim "authorized_keys, authorizing this machine to SSH in."
  printf '\n'

  # Step: Update AI harness instruction files
  printf "${BOLD}  4. AI Harness Instructions${RESET}\n"
  update_harness_instructions
  printf '\n'

  ok "Setup complete. This screen will stay visible."
  dim "Press Ctrl+C to close."
  printf '\n'

  # Keep process alive so user can photograph
  # Clean up tunnel on exit
  cleanup() {
    [ -n "$TUNNEL_PID" ] && kill "$TUNNEL_PID" 2>/dev/null
    printf "\n"
  }
  trap cleanup EXIT INT TERM
  while true; do sleep 86400; done
}

cmd_setup_help() {
  printf 'Usage: agent-bridge setup [OPTIONS]\n\n'
  printf 'Enables SSH, generates keys, and displays a pairing screen.\n'
  printf 'Run on each machine you want to bridge.\n\n'
  printf 'Options:\n'
  printf '  -n, --name <name>              Machine name (defaults to hostname)\n'
  printf '  -p, --port <port>              SSH port (default: 22)\n'
  printf '      --internet                 Start a reverse SSH tunnel for internet access\n'
  printf '      --tunnel-provider <name>   Tunnel provider (default: serveo). Supported: serveo\n'
  printf '  -h, --help                     Show this help\n'
}

cmd_pair() {
  local machine_name="" host="" user="" port="22" keypath="" token="" pubkey=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --name|-n)    machine_name="$2"; shift 2 ;;
      --host|-H)    host="$2"; shift 2 ;;
      --user|-u)    user="$2"; shift 2 ;;
      --port|-p)    port="$2"; shift 2 ;;
      --key|-k)     keypath="$2"; shift 2 ;;
      --token|-t)   token="$2"; shift 2 ;;
      --pubkey)     pubkey="$2"; shift 2 ;;
      --manual|-m)  shift ;;  # No-op, kept for compat
      --help|-h)    cmd_pair_help; exit 0 ;;
      -*)           die "Unknown option: $1. Use --help for usage." ;;
      *)
        # Positional argument — could be a JSON/text file
        if [ -f "$1" ]; then
          dim "File pairing not supported in bash version. Use --name/--host/--user flags."
          exit 1
        fi
        die "Unknown argument: $1"
        ;;
    esac
  done

  # Interactive mode if missing required fields
  if [ -z "$host" ] || [ -z "$user" ]; then
    printf '\n'
    printf "${BOLD}${CYAN}  agent-bridge pair${RESET}\n"
    printf '\n'

    if [ -z "$machine_name" ]; then
      printf '  Machine name: '
      read -r machine_name
    fi
    if [ -z "$host" ]; then
      printf '  Host (IP or hostname): '
      read -r host
    fi
    if [ -z "$user" ]; then
      printf '  User: '
      read -r user
    fi
    printf '  Port [%s]: ' "$port"
    read -r input_port
    [ -n "$input_port" ] && port="$input_port"

    if [ -z "$token" ]; then
      printf '  Pairing token (from setup screen): '
      read -r token
    fi

    if [ -z "$pubkey" ]; then
      printf '  Public key from the other machine'\''s setup screen:\n'
      printf '  > '
      read -r pubkey
    fi
  fi

  [ -z "$machine_name" ] && machine_name="$host"
  [ -z "$host" ] && die "Host is required."
  [ -z "$user" ] && die "User is required."
  [ -z "$token" ] && die "Pairing token is required. Check the setup screen on the other machine."
  [ -z "$pubkey" ] && die "Public key is required. Copy it from the other machine's setup screen."

  printf '\n'
  printf "${BOLD}${CYAN}  agent-bridge pair${RESET}\n"
  printf '\n'

  # Step 1: Generate local key pair (if not already present and no --key override)
  ensure_config_dir
  local local_machine
  local_machine="$(get_machine_name)"
  local local_key="$KEYS_DIR/agent-bridge_${local_machine}"
  local local_pub="${local_key}.pub"

  if [ -n "$keypath" ]; then
    # User supplied a specific key — use it as-is (override mode)
    keypath="${keypath/#\~/$HOME}"
    printf "${BOLD}  1. SSH Key${RESET}\n"
    if [ -f "$keypath" ]; then
      ok "Using provided key: $keypath"
    else
      die "Key file not found: $keypath"
    fi
  else
    # Default: use the key from setup (saved in .identity), or fall back to hostname-based key
    printf "${BOLD}  1. Local Key Pair${RESET}\n"
    if [ -f "$CONFIG_DIR/.identity" ]; then
      local_key="$(cat "$CONFIG_DIR/.identity")"
      local_pub="${local_key}.pub"
      dim "Using setup key: $(basename "$local_key")"
    fi
    if [ -f "$local_key" ] && [ -f "$local_pub" ]; then
      dim "Key pair found for $local_machine."
    else
      dim "Generating SSH key pair for $local_machine..."
      ssh-keygen -t ed25519 -f "$local_key" -N "" -C "agent-bridge:${local_machine}" >/dev/null 2>&1
      chmod 600 "$local_key"
      ok "Key pair generated: $local_key"
    fi
    keypath="$local_key"
  fi
  printf '\n'

  # Step 2: Authorize the other machine's public key on THIS machine
  printf "${BOLD}  2. Authorize Remote Key${RESET}\n"
  local ssh_dir="$HOME/.ssh"
  local auth_keys="$ssh_dir/authorized_keys"
  [ -d "$ssh_dir" ] || mkdir -p "$ssh_dir" && chmod 700 "$ssh_dir"

  if [ -f "$auth_keys" ] && grep -qF "$pubkey" "$auth_keys" 2>/dev/null; then
    dim "Public key already in authorized_keys."
  else
    printf '%s\n' "$pubkey" >> "$auth_keys"
    sort -u "$auth_keys" -o "$auth_keys"
    chmod 600 "$auth_keys"
    ok "Remote public key added to ~/.ssh/authorized_keys."
  fi
  dim "The other machine can now SSH into this one."
  printf '\n'

  # Step 3: Token accepted as human-verification (no remote check)
  printf "${BOLD}  3. Token Verification${RESET}\n"
  ok "Token accepted: $token"
  dim "Token is recorded for human verification (no remote connection needed)."
  printf '\n'

  # Step 4: Save pairing config
  cfg_save "$machine_name" "$host" "$user" "$port" "$keypath"

  printf "${GREEN}${BOLD}  [ok] Paired with \"%s\"!${RESET}\n" "$machine_name"
  printf '\n'
  printf "  Connection details:\n"
  printf "${DIM}    Host:     %s${RESET}\n" "$host"
  printf "${DIM}    Port:     %s${RESET}\n" "$port"
  printf "${DIM}    User:     %s${RESET}\n" "$user"
  printf "${DIM}    Key:      %s${RESET}\n" "$keypath"
  printf '\n'
  printf "  The other machine's public key has been authorized on this machine.\n"
  printf "  For bidirectional access, run 'pair' on the other machine too.\n"
  printf '\n'
  printf "  Try it out:\n"
  printf "${DIM}    agent-bridge status %s${RESET}\n" "$machine_name"
  printf "${DIM}    agent-bridge run %s \"uname -a\"${RESET}\n" "$machine_name"
  printf "${DIM}    agent-bridge connect %s${RESET}\n" "$machine_name"
  printf '\n'

  # Update AI harness instruction files with new pairing info
  printf "${BOLD}  5. AI Harness Instructions${RESET}\n"
  update_harness_instructions
  printf '\n'
}

cmd_pair_help() {
  printf 'Usage: agent-bridge pair [OPTIONS]\n\n'
  printf 'Pair with another machine. Interactive if flags are omitted.\n\n'
  printf 'Reads the other machine'\''s public key from the setup screen and adds it\n'
  printf 'to ~/.ssh/authorized_keys, authorizing that machine to SSH in. No\n'
  printf 'password prompt, no SSH connection during pairing.\n\n'
  printf 'For bidirectional access, run pair on both machines.\n\n'
  printf 'Options:\n'
  printf '  -n, --name <name>       Machine name (defaults to host)\n'
  printf '  -H, --host <host>       Hostname or IP of the other machine\n'
  printf '  -u, --user <user>       SSH username\n'
  printf '  -p, --port <port>       SSH port (default: 22)\n'
  printf '  -k, --key <key>         Path to existing SSH private key (override)\n'
  printf '  -t, --token <token>     Pairing token from setup screen\n'
  printf '      --pubkey <key>      Public key from the other machine'\''s setup screen\n'
  printf '  -m, --manual            (Kept for compat, no-op)\n'
  printf '  -h, --help              Show this help\n'
}

cmd_connect() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_connect_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge connect <machine>"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  local host user port keypath
  host="$(cfg_get "$machine_name" host)"
  user="$(cfg_get "$machine_name" user)"
  port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"

  printf '\n'
  printf "${CYAN}  Connecting to ${BOLD}%s${RESET}${CYAN} (%s@%s)...${RESET}\n" "$machine_name" "$user" "$host"
  printf '\n'

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-p" "$port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath")
  fi
  args+=("${user}@${host}")

  ssh "${args[@]}"
  local exit_code=$?

  printf '\n'
  if [ "$exit_code" -eq 0 ]; then
    dim "Connection closed."
  else
    printf "${YELLOW}  SSH exited with code %d.${RESET}\n" "$exit_code"
  fi
}

cmd_connect_help() {
  printf 'Usage: agent-bridge connect <machine>\n\n'
  printf 'Open an interactive SSH session to a paired machine.\n'
}

cmd_run() {
  local machine_name="" command=""

  # Parse args — machine and command are positional
  while [ $# -gt 0 ]; do
    case "$1" in
      --agent|--claude|--codex)
        die "The $1 flag was removed in agent-bridge 3.0.0. 'agent-bridge run' is a plain remote-shell utility only — it does NOT spawn agents. To talk to the running agent on another machine, use the channel plugin's bridge_send_message MCP tool."
        ;;
      --help|-h) cmd_run_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)
        if [ -z "$machine_name" ]; then
          machine_name="$1"
        elif [ -z "$command" ]; then
          command="$1"
        else
          die "Unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge run <machine> \"shell command\""
  [ -z "$command" ] && die "Command required. Usage: agent-bridge run <machine> \"shell command\""

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  local host user port keypath
  host="$(cfg_get "$machine_name" host)"
  user="$(cfg_get "$machine_name" user)"
  port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"

  printf "${DIM}  Running command on %s...${RESET}\n" "$machine_name"

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-p" "$port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath")
  fi
  args+=("${user}@${host}" "$command")

  local exit_code=0
  ssh "${args[@]}" || exit_code=$?

  printf '\n'
  if [ "$exit_code" -eq 0 ]; then
    ok "command completed on $machine_name (exit 0)"
  else
    printf "${YELLOW}  command on %s exited with code %d.${RESET}\n" "$machine_name" "$exit_code"
  fi

  exit "$exit_code"
}

cmd_run_help() {
  printf 'Usage: agent-bridge run <machine> "shell command"\n\n'
  printf 'Run a PLAIN shell command on a paired machine over SSH.\n\n'
  printf 'This is a diagnostic utility — use it for things like `git status`,\n'
  printf '`ls ~/Projects`, `ps aux`, checking file paths, tailing logs, etc.\n\n'
  printf 'To talk to the RUNNING agent on another paired machine, use the\n'
  printf 'agent-bridge channel plugin and its `bridge_send_message` MCP tool.\n'
  printf 'That is the ONLY supported agent-to-agent communication path.\n\n'
  printf 'The `--claude`, `--codex`, and `--agent` flags were REMOVED in\n'
  printf 'agent-bridge 3.0.0. They spawned a new non-interactive agent session\n'
  printf 'on the remote machine (e.g. `claude --print`), which is exactly what\n'
  printf 'this project is NOT meant to encourage.\n\n'
  printf 'Options:\n'
  printf '  -h, --help     Show this help\n'
}

cmd_list() {
  printf '\n'
  printf "${BOLD}${CYAN}  agent-bridge list${RESET}\n"
  printf '\n'

  local names
  names="$(cfg_list_names)"

  if [ -z "$names" ]; then
    dim "No paired machines."
    printf '\n'
    dim "To pair a machine:"
    dim "  1. Run 'agent-bridge setup' on the other machine"
    dim "  2. Send a photo of the pairing screen to this machine's Claude"
    dim "  3. Run 'agent-bridge pair' here with the details"
    printf '\n'
    return
  fi

  local count=0
  while IFS= read -r name; do
    [ -z "$name" ] && continue
    count=$((count + 1))
    local host user port keypath paired_at
    host="$(cfg_get "$name" host 2>/dev/null || printf 'unknown')"
    user="$(cfg_get "$name" user 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$name" port 2>/dev/null || printf '22')"
    keypath="$(cfg_get "$name" key 2>/dev/null || printf '(system default)')"
    paired_at="$(cfg_get "$name" paired_at 2>/dev/null || true)"

    printf "${BOLD}  %s${RESET}\n" "$name"
    printf "${DIM}    Host:       %s${RESET}\n" "$host"
    printf "${DIM}    Port:       %s${RESET}\n" "$port"
    printf "${DIM}    User:       %s${RESET}\n" "$user"
    printf "${DIM}    Key:        %s${RESET}\n" "$keypath"
    if [ -n "$paired_at" ]; then
      printf "${DIM}    Paired:     %s${RESET}\n" "$paired_at"
    fi
    printf '\n'
  done <<< "$names"

  dim "$count machine$([ "$count" -ne 1 ] && printf 's') paired."
  printf '\n'
}

cmd_status() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_status_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  printf '\n'
  printf "${BOLD}${CYAN}  agent-bridge status${RESET}\n"
  printf '\n'

  check_machine() {
    local name="$1"
    local host user port keypath
    host="$(cfg_get "$name" host 2>/dev/null || printf 'unknown')"
    user="$(cfg_get "$name" user 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$name" port 2>/dev/null || printf '22')"
    keypath="$(cfg_get "$name" key 2>/dev/null || true)"
    keypath="${keypath/#\~/$HOME}"

    local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=5" "-p" "$port")
    if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
      args+=("-i" "$keypath")
    fi
    args+=("${user}@${host}" "echo ok")

    local start_time
    if is_macos; then
      start_time=$(perl -MTime::HiRes=time -e 'printf "%.0f\n", time*1000')
    else
      start_time=$(($(date +%s%N) / 1000000))
    fi

    if ssh "${args[@]}" >/dev/null 2>&1; then
      local end_time
      if is_macos; then
        end_time=$(perl -MTime::HiRes=time -e 'printf "%.0f\n", time*1000')
      else
        end_time=$(($(date +%s%N) / 1000000))
      fi
      local latency=$((end_time - start_time))
      printf "${GREEN}  %s${RESET}${DIM} (%s@%s:%s) -- %dms${RESET}\n" "$name" "$user" "$host" "$port" "$latency"
      return 0
    else
      printf "${RED}  %s${RESET}${DIM} (%s) -- unreachable${RESET}\n" "$name" "$host"
      return 1
    fi
  }

  if [ -n "$machine_name" ]; then
    if ! cfg_exists "$machine_name"; then
      die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
    fi
    check_machine "$machine_name"
  else
    local names
    names="$(cfg_list_names)"

    if [ -z "$names" ]; then
      dim "No paired machines."
      dim "Run 'agent-bridge setup' on each machine, then 'agent-bridge pair' to connect them."
      printf '\n'
      return
    fi

    local total=0 reachable=0
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      total=$((total + 1))
      if check_machine "$name"; then
        reachable=$((reachable + 1))
      fi
    done <<< "$names"

    printf '\n'
    dim "$reachable/$total machines reachable."
  fi

  printf '\n'
}

cmd_status_help() {
  printf 'Usage: agent-bridge status [machine]\n\n'
  printf 'Check if paired machine(s) are reachable.\n'
  printf 'Omit machine name to check all.\n'
}

cmd_unpair() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_unpair_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge unpair <machine>"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  # Try to remove the key file
  local keypath
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ] && [ -f "$keypath" ]; then
    rm -f "$keypath" 2>/dev/null && dim "Removed key: $keypath" || warn "Could not remove key at $keypath"
    # Also remove .pub if it exists
    [ -f "${keypath}.pub" ] && rm -f "${keypath}.pub" 2>/dev/null
  fi

  cfg_remove "$machine_name"
  printf '\n'
  ok "Unpaired \"$machine_name\"."
  printf '\n'
}

cmd_unpair_help() {
  printf 'Usage: agent-bridge unpair <machine>\n\n'
  printf 'Remove a paired machine and its SSH key.\n'
}

# -- send-action --------------------------------------------------------------
# Drop a JSON action file into a paired machine's ~/.agent-bridge/actions/
# inbox, where its actions-daemon LaunchAgent will pick it up and execute
# a fixed GUI keystroke action (send-enter / send-text / send-ctrl-c).
# See actions-daemon/README.md for the daemon design and threat model.
cmd_send_action() {
  local machine_name="" action="" target=""
  local -a positional=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_send_action_help; exit 0 ;;
      --target)  target="${2:-}"; shift 2 ;;
      --target=*) target="${1#--target=}"; shift ;;
      -*)        die "Unknown option: $1" ;;
      *)
        if [ -z "$machine_name" ]; then
          machine_name="$1"
        elif [ -z "$action" ]; then
          action="$1"
        else
          positional+=("$1")
        fi
        shift
        ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge send-action <machine> <action> [args...]"
  [ -z "$action" ]       && die "Action required. Usage: agent-bridge send-action <machine> <action> [args...]"

  case "$action" in
    send-enter|send-text|send-ctrl-c) ;;
    *) die "Unsupported action: $action. Supported: send-enter, send-text, send-ctrl-c." ;;
  esac

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  # Generate UUID. Prefer uuidgen, fall back to /dev/urandom.
  local id
  if command -v uuidgen >/dev/null 2>&1; then
    id="msg-$(uuidgen | tr '[:upper:]' '[:lower:]')"
  else
    id="msg-$(od -An -N16 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')"
  fi

  local ts
  ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

  # Build JSON args array from remaining positionals.
  local args_json="[]"
  if [ "${#positional[@]}" -gt 0 ]; then
    if command -v jq >/dev/null 2>&1; then
      args_json="$(printf '%s\n' "${positional[@]}" | jq -R . | jq -s -c .)"
    else
      # Minimal fallback: escape backslash and double-quote only.
      local first=1 a esc
      args_json="["
      for a in "${positional[@]}"; do
        esc="${a//\\/\\\\}"; esc="${esc//\"/\\\"}"
        if [ "$first" -eq 1 ]; then
          args_json+="\"${esc}\""
          first=0
        else
          args_json+=",\"${esc}\""
        fi
      done
      args_json+="]"
    fi
  fi

  local target_json="null"
  if [ -n "$target" ]; then
    local esc="${target//\\/\\\\}"; esc="${esc//\"/\\\"}"
    target_json="\"${esc}\""
  fi

  local json
  json="$(printf '{"id":"%s","action":"%s","target":%s,"args":%s,"timestamp":"%s"}' \
    "$id" "$action" "$target_json" "$args_json" "$ts")"

  # Ship it over SSH using the paired key. We do not scp — piping through
  # ssh into cat avoids needing a second temp file on the sending side and
  # matches the style used elsewhere in this CLI.
  local host user port keypath
  host="$(cfg_get "$machine_name" host)"
  user="$(cfg_get "$machine_name" user)"
  port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"

  local -a ssh_args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-p" "$port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    ssh_args+=("-i" "$keypath")
  fi
  ssh_args+=("${user}@${host}")

  local remote_path="\$HOME/.agent-bridge/actions/${id}.json"
  local remote_cmd="mkdir -p \$HOME/.agent-bridge/actions && chmod 700 \$HOME/.agent-bridge/actions && umask 077 && cat > ${remote_path}"

  printf "${DIM}  Sending action %s to %s...${RESET}\n" "$action" "$machine_name"

  if ! printf '%s' "$json" | ssh "${ssh_args[@]}" "$remote_cmd"; then
    die "Failed to deliver action file to $machine_name."
  fi

  printf '\n'
  ok "queued $action on $machine_name"
  printf "${DIM}  id:     %s${RESET}\n" "$id"
  printf "${DIM}  remote: ~/.agent-bridge/actions/%s.json${RESET}\n" "$id"
  printf '\n'
}

