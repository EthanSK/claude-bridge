cmd_status() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h)       cmd_status_help; exit 0 ;;
      --probe|--fresh)
        # Bypass the last-reachable-path cache for this invocation (force
        # LAN-first probe and refresh the cache from scratch).
        PATH_CACHE_BYPASS=1
        shift ;;
      -*)              die "Unknown option: $1" ;;
      *)               machine_name="$1"; shift ;;
    esac
  done

  printf '\n'
  printf "${BOLD}${CYAN}  agent-bridge status${RESET}\n"
  printf '\n'

  # Timestamp helper in milliseconds.
  _status_now_ms() {
    if is_macos; then
      perl -MTime::HiRes=time -e 'printf "%.0f\n", time*1000'
    else
      printf '%d' "$(($(date +%s%N) / 1000000))"
    fi
  }

  check_machine() {
    local name="$1"
    local host user port keypath internet_host internet_port
    host="$(cfg_get "$name" host 2>/dev/null || printf 'unknown')"
    user="$(cfg_get "$name" user 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$name" port 2>/dev/null || printf '22')"
    keypath="$(cfg_get "$name" key 2>/dev/null || true)"
    keypath="${keypath/#\~/$HOME}"
    internet_host="$(cfg_get "$name" internet_host 2>/dev/null || true)"
    internet_port="$(cfg_get "$name" internet_port 2>/dev/null || printf '22')"

    local has_fallback=0
    [ -n "$internet_host" ] && has_fallback=1

    # Cache-informed attempt order (or LAN-only when no fallback configured).
    local order
    if [ "$has_fallback" = "1" ]; then
      order="$(path_cache_order "$name")"
    else
      order="lan"
    fi

    local last_attempt=""
    local attempt
    while IFS= read -r attempt; do
      [ -z "$attempt" ] && continue
      last_attempt="$attempt"
      local try_host try_port try_timeout path_label
      if [ "$attempt" = "lan" ]; then
        try_host="$host"; try_port="$port"
        try_timeout=5
        [ "$has_fallback" = "1" ] && try_timeout=3
        path_label="LAN"
      else
        try_host="$internet_host"; try_port="$internet_port"
        try_timeout=10
        path_label="internet"
      fi

      local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=${try_timeout}" "-p" "$try_port")
      if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
        args+=("-i" "$keypath")
      fi
      args+=("${user}@${try_host}" "echo ok")

      local start_time end_time probe_exit=0
      start_time="$(_status_now_ms)"
      ssh "${args[@]}" >/dev/null 2>&1 || probe_exit=$?
      end_time="$(_status_now_ms)"

      if [ "$probe_exit" -eq 0 ]; then
        local latency=$((end_time - start_time))
        path_cache_write "$name" "$attempt" 2>/dev/null || true
        printf "${GREEN}  %s${RESET}${DIM} (%s@%s:%s via %s) -- %dms${RESET}\n" "$name" "$user" "$try_host" "$try_port" "$path_label" "$latency"
        return 0
      fi

      if [ "$probe_exit" -ne 255 ]; then
        # Non-connection error (e.g. `echo ok` itself failed). Don't bother
        # trying the other path for something that isn't a connectivity issue.
        printf "${RED}  %s${RESET}${DIM} (%s via %s) -- probe exit %d${RESET}\n" "$name" "$try_host" "$path_label" "$probe_exit"
        return 1
      fi
    done <<< "$order"

    if [ "$has_fallback" = "1" ]; then
      printf "${RED}  %s${RESET}${DIM} -- unreachable on both LAN (%s) and internet (%s)${RESET}\n" "$name" "$host" "$internet_host"
    else
      printf "${RED}  %s${RESET}${DIM} (%s) -- unreachable${RESET}\n" "$name" "$host"
    fi
    return 1
  }

  if [ -n "$machine_name" ]; then
    if ! cfg_exists "$machine_name"; then
      die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
    fi
    check_machine "$machine_name"
  else
    local names
    names="$(cfg_list_names)"

    if [ -z "$names" ]; then
      dim "No paired machines."
      dim "Run 'agent-bridge setup' on each machine, then 'agent-bridge pair' to connect them."
      printf '\n'
      return
    fi

    local total=0 reachable=0
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      total=$((total + 1))
      if check_machine "$name"; then
        reachable=$((reachable + 1))
      fi
    done <<< "$names"

    printf '\n'
    dim "$reachable/$total machines reachable."
  fi

  printf '\n'
}

