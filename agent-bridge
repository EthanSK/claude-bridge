cmd_connect() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_connect_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge connect <machine>"

  if is_local_machine "$machine_name"; then
    die "\"$machine_name\" is the local machine. agent-bridge connect opens an SSH session to a remote machine — open a new terminal locally instead."
  fi

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  local host user port keypath internet_host internet_port
  host="$(cfg_get "$machine_name" host)"
  user="$(cfg_get "$machine_name" user)"
  port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
  keypath="$(cfg_identity_file "$machine_name")"
  internet_host="$(cfg_get "$machine_name" internet_host 2>/dev/null || true)"
  internet_port="$(cfg_get "$machine_name" internet_port 2>/dev/null || printf '22')"

  # 3.4.2+ policy: Tailscale-first, no fallback.
  local try_host try_port chosen
  if [ -n "$internet_host" ]; then
    try_host="$internet_host"; try_port="$internet_port"; chosen="internet"
  else
    try_host="$host"; try_port="$port"; chosen="lan"
  fi

  printf '\n'
  printf "${CYAN}  Connecting to ${BOLD}%s${RESET}${CYAN} (%s@%s via %s)...${RESET}\n" \
    "$machine_name" "$user" "$try_host" "$chosen"
  printf '\n'

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=10" "-p" "$try_port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath" "-o" "IdentitiesOnly=yes")
  fi
  args+=("${user}@${try_host}")

  local exit_code=0
  ssh "${args[@]}" || exit_code=$?

  if [ "$exit_code" -ne 255 ]; then
    path_cache_write "$machine_name" "$chosen" 2>/dev/null || true
  fi

  printf '\n'
  if [ "$exit_code" -eq 0 ]; then
    dim "Connection closed."
  else
    printf "${YELLOW}  SSH exited with code %d.${RESET}\n" "$exit_code"
  fi
}

cmd_connect_help() {
  printf 'Usage: agent-bridge connect <machine>\n\n'
  printf 'Open an interactive SSH session to a paired machine.\n'
}

cmd_run() {
  local machine_name="" command=""

  # Parse args — machine and command are positional
  while [ $# -gt 0 ]; do
    case "$1" in
      --agent|--claude|--codex)
        die "The $1 flag was removed in agent-bridge 3.0.0. 'agent-bridge run' is a plain remote-shell utility only — it does NOT spawn agents. To talk to the running agent on another machine, use the channel plugin's bridge_send_message MCP tool."
        ;;
      --help|-h) cmd_run_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)
        if [ -z "$machine_name" ]; then
          machine_name="$1"
        elif [ -z "$command" ]; then
          command="$1"
        else
          die "Unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge run <machine> \"shell command\""
  [ -z "$command" ] && die "Command required. Usage: agent-bridge run <machine> \"shell command\""

  if is_local_machine "$machine_name"; then
    die "\"$machine_name\" is the local machine. agent-bridge run is for remote machines only — there is no SSH loopback. Run the command directly in your shell."
  fi

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  local host user port keypath internet_host internet_port
  host="$(cfg_get "$machine_name" host)"
  user="$(cfg_get "$machine_name" user)"
  port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
  keypath="$(cfg_identity_file "$machine_name")"
  internet_host="$(cfg_get "$machine_name" internet_host 2>/dev/null || true)"
  internet_port="$(cfg_get "$machine_name" internet_port 2>/dev/null || printf '22')"

  # 3.4.2+ policy: Tailscale-first, no fallback.
  local try_host try_port chosen
  if [ -n "$internet_host" ]; then
    try_host="$internet_host"; try_port="$internet_port"; chosen="internet"
  else
    try_host="$host"; try_port="$port"; chosen="lan"
  fi

  printf "${DIM}  Running command on %s (via %s)...${RESET}\n" "$machine_name" "$chosen"
  log_event info "cli.run.start" "running command on $machine_name" "{\"machine\":\"$machine_name\",\"path\":\"$chosen\",\"command_length\":${#command}}"

  local exit_code=0
  local stderr_file client_log
  stderr_file="$(mktemp -t ab-ssh-err.XXXXXX)"
  client_log="$(mktemp -t ab-ssh-log.XXXXXX)"
  trap 'rm -f "$stderr_file" "$client_log"' EXIT

  # Capture client-side SSH diagnostics via -E so connection failures are
  # always visible even when stderr would be silent.
  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "ConnectTimeout=10" "-p" "$try_port" "-E" "$client_log" "-o" "LogLevel=INFO")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath" "-o" "IdentitiesOnly=yes")
  fi
  args+=("${user}@${try_host}" "$command")

  # Tee stderr so the user sees it live; no retry/fallback happens so we just
  # let ssh's own error reporting surface.
  ssh "${args[@]}" 2> >(tee "$stderr_file" >&2) || exit_code=$?
  wait 2>/dev/null || true

  if [ "$exit_code" -ne 255 ]; then
    path_cache_write "$machine_name" "$chosen" 2>/dev/null || true
  fi

  printf '\n'
  if [ "$exit_code" -eq 0 ]; then
    ok "command completed on $machine_name (exit 0)"
    log_event info "cli.run.done" "command completed on $machine_name" "{\"machine\":\"$machine_name\",\"exit_code\":0}"
  else
    printf "${YELLOW}  command on %s exited with code %d.${RESET}\n" "$machine_name" "$exit_code"
    log_event warn "cli.run.failed" "command on $machine_name exited non-zero" "{\"machine\":\"$machine_name\",\"exit_code\":$exit_code}"
  fi

  exit "$exit_code"
}

cmd_run_help() {
  printf 'Usage: agent-bridge run <machine> "shell command"\n\n'
  printf 'Run a PLAIN shell command on a paired machine over SSH.\n\n'
  printf 'This is a diagnostic utility — use it for things like `git status`,\n'
  printf '`ls ~/Projects`, `ps aux`, checking file paths, tailing logs, etc.\n\n'
  printf 'To talk to the RUNNING agent on another paired machine, use the\n'
  printf 'agent-bridge channel plugin and its `bridge_send_message` MCP tool.\n'
  printf 'That is the ONLY supported agent-to-agent communication path.\n\n'
  printf 'The `--claude`, `--codex`, and `--agent` flags were REMOVED in\n'
  printf 'agent-bridge 3.0.0. They spawned a new non-interactive agent session\n'
  printf 'on the remote machine (e.g. `claude --print`), which is exactly what\n'
  printf 'this project is NOT meant to encourage.\n\n'
  printf 'Options:\n'
  printf '  -h, --help     Show this help\n'
}

cmd_list() {
  printf '\n'
  printf "${BOLD}${CYAN}  agent-bridge list${RESET}\n"
  printf '\n'

  local names
  names="$(cfg_list_names)"

  if [ -z "$names" ]; then
    dim "No paired machines."
    printf '\n'
    dim "To pair a machine:"
    dim "  1. Run 'agent-bridge setup' on the other machine"
    dim "  2. Send a photo of the pairing screen to this machine's Claude"
    dim "  3. Run 'agent-bridge pair' here with the details"
    printf '\n'
    return
  fi

  local count=0
  while IFS= read -r name; do
    [ -z "$name" ] && continue
    count=$((count + 1))
    local host user port keypath paired_at
    host="$(cfg_get "$name" host 2>/dev/null || printf 'unknown')"
    user="$(cfg_get "$name" user 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$name" port 2>/dev/null || printf '22')"
    keypath="$(cfg_identity_file "$name")"
    [ -n "$keypath" ] || keypath="(system default)"
    paired_at="$(cfg_get "$name" paired_at 2>/dev/null || true)"

    local ihost iport
    ihost="$(cfg_get "$name" internet_host 2>/dev/null || true)"
    iport="$(cfg_get "$name" internet_port 2>/dev/null || true)"

    printf "${BOLD}  %s${RESET}\n" "$name"
    printf "${DIM}    Host:       %s${RESET}\n" "$host"
    printf "${DIM}    Port:       %s${RESET}\n" "$port"
    if [ -n "$ihost" ]; then
      printf "${DIM}    Internet:   %s:%s${RESET}\n" "$ihost" "${iport:-22}"
    fi
    printf "${DIM}    User:       %s${RESET}\n" "$user"
    printf "${DIM}    Key:        %s${RESET}\n" "$keypath"
    if [ -n "$paired_at" ]; then
      printf "${DIM}    Paired:     %s${RESET}\n" "$paired_at"
    fi
    printf '\n'
  done <<< "$names"

  dim "$count machine$([ "$count" -ne 1 ] && printf 's') paired."
  printf '\n'
}

cmd_status() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h)       cmd_status_help; exit 0 ;;
      --probe|--fresh)
        # Accepted for compatibility. 3.4.2+ endpoint selection ignores
        # the legacy path cache, so this does not change the probed endpoint.
        PATH_CACHE_BYPASS=1
        shift ;;
      -*)              die "Unknown option: $1" ;;
      *)               machine_name="$1"; shift ;;
    esac
  done

  printf '\n'
  printf "${BOLD}${CYAN}  agent-bridge status${RESET}\n"
  printf '\n'

  # Timestamp helper in milliseconds.
  _status_now_ms() {
    if is_macos; then
      perl -MTime::HiRes=time -e 'printf "%.0f\n", time*1000'
    else
      printf '%d' "$(($(date +%s%N) / 1000000))"
    fi
  }

  check_machine() {
    local name="$1"
    local host user port keypath internet_host internet_port
    host="$(cfg_get "$name" host 2>/dev/null || printf 'unknown')"
    user="$(cfg_get "$name" user 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$name" port 2>/dev/null || printf '22')"
    keypath="$(cfg_identity_file "$name")"
    internet_host="$(cfg_get "$name" internet_host 2>/dev/null || true)"
    internet_port="$(cfg_get "$name" internet_port 2>/dev/null || printf '22')"

    # 3.4.2+ policy: Tailscale-first, no fallback. Pick a single endpoint.
    local try_host try_port path_label chosen
    if [ -n "$internet_host" ]; then
      try_host="$internet_host"; try_port="$internet_port"
      path_label="internet"; chosen="internet"
    else
      try_host="$host"; try_port="$port"
      path_label="LAN"; chosen="lan"
    fi

    local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=10" "-p" "$try_port")
    if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
      args+=("-i" "$keypath" "-o" "IdentitiesOnly=yes")
    fi
    args+=("${user}@${try_host}" "echo ok")

    local start_time end_time probe_exit=0
    start_time="$(_status_now_ms)"
    ssh "${args[@]}" </dev/null >/dev/null 2>&1 || probe_exit=$?
    end_time="$(_status_now_ms)"

    if [ "$probe_exit" -eq 0 ]; then
      local latency=$((end_time - start_time))
      path_cache_write "$name" "$chosen" 2>/dev/null || true
      printf "${GREEN}  %s${RESET}${DIM} (%s@%s:%s via %s) -- %dms${RESET}\n" \
        "$name" "$user" "$try_host" "$try_port" "$path_label" "$latency"
      log_event info "cli.status.online" "$name reachable via $path_label" \
        "{\"machine\":\"$name\",\"path\":\"$path_label\",\"host\":\"$try_host\",\"latency_ms\":$latency}"
      return 0
    fi

    if [ "$probe_exit" -ne 255 ]; then
      printf "${RED}  %s${RESET}${DIM} (%s via %s) -- probe exit %d${RESET}\n" \
        "$name" "$try_host" "$path_label" "$probe_exit"
      log_event warn "cli.status.probe_error" "$name probe non-255 exit" \
        "{\"machine\":\"$name\",\"path\":\"$path_label\",\"exit_code\":$probe_exit}"
      return 1
    fi

    printf "${RED}  %s${RESET}${DIM} (%s:%s via %s) -- unreachable${RESET}\n" \
      "$name" "$try_host" "$try_port" "$path_label"
    log_event warn "cli.status.offline" "$name unreachable via $path_label" \
      "{\"machine\":\"$name\",\"path\":\"$path_label\",\"host\":\"$try_host\"}"
    return 1
  }

  if [ -n "$machine_name" ]; then
    if is_local_machine "$machine_name"; then
      local local_name
      local_name="$(get_machine_name)"
      printf "${GREEN}  %s${RESET}${DIM} (LOCAL — same-machine delivery, no SSH)${RESET}\n" "$local_name"
      log_event info "cli.status.local" "$local_name local-machine status reported" \
        "{\"machine\":\"$local_name\",\"transport\":\"local\"}"
      printf '\n'
      return 0
    fi
    if ! cfg_exists "$machine_name"; then
      die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
    fi
    check_machine "$machine_name"
  else
    local names
    names="$(cfg_list_names)"

    local local_name
    local_name="$(get_machine_name)"
    printf "${GREEN}  %s${RESET}${DIM} (LOCAL — same-machine delivery, no SSH)${RESET}\n" "$local_name"

    if [ -z "$names" ]; then
      printf '\n'
      dim "No paired remote machines."
      dim "Run 'agent-bridge setup' on each machine, then 'agent-bridge pair' to connect them."
      printf '\n'
      return
    fi

    local total=0 reachable=0
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      total=$((total + 1))
      if check_machine "$name"; then
        reachable=$((reachable + 1))
      fi
    done <<< "$names"

    printf '\n'
    dim "$reachable/$total remote machines reachable (plus $local_name local)."
  fi

  printf '\n'
}

cmd_status_help() {
  printf 'Usage: agent-bridge status [--probe|--fresh] [machine]\n\n'
  printf 'Check if paired machine(s) are reachable.\n'
  printf 'Omit machine name to check all.\n\n'
  printf 'As of 3.4.2, status uses a single endpoint per machine:\n'
  printf '  - `internet_host` (Tailscale) when configured\n'
  printf '  - `host` (LAN) otherwise\n'
  printf 'No fallback is attempted — status reports reachability on the\n'
  printf 'configured preferred path only.\n\n'
  printf 'Options:\n'
  printf '  --probe, --fresh   Retained for compatibility. No-op in 3.4.2+.\n'
  printf '  -h, --help         Show this help\n'
}

# -- reset-path ---------------------------------------------------------------
cmd_reset_path() {
  local machine_name="" all=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --all)     all=1; shift ;;
      --help|-h) cmd_reset_path_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  if [ "$all" = "1" ]; then
    if [ -f "$PATH_CACHE_FILE" ]; then
      rm -f "$PATH_CACHE_FILE"
      ok "Cleared path cache for all machines."
    else
      dim "No path cache to clear."
    fi
    return 0
  fi

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge reset-path <machine> (or --all)"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  path_cache_clear "$machine_name"
  ok "Cleared cached reachable path for $machine_name. (3.4.2+: endpoint selection no longer uses the cache — command kept for compatibility.)"
}

cmd_reset_path_help() {
  printf 'Usage: agent-bridge reset-path <machine>\n'
  printf '       agent-bridge reset-path --all\n\n'
  printf 'Invalidate the cached last-reachable-path entry for a machine.\n\n'
  printf 'Note: as of 3.4.2 agent-bridge no longer uses the path cache to\n'
  printf 'select an endpoint. It always prefers `internet_host` (Tailscale)\n'
  printf 'when configured and only falls back to LAN when it is not. The\n'
  printf 'cache is still written for observability, and this command is\n'
  printf 'retained purely for backwards compatibility.\n'
}

cmd_unpair() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_unpair_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge unpair <machine>"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  # Try to remove the key file
  local keypath
  keypath="$(cfg_identity_file "$machine_name")"
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ] && [ -f "$keypath" ]; then
    rm -f "$keypath" 2>/dev/null && dim "Removed key: $keypath" || warn "Could not remove key at $keypath"
    # Also remove .pub if it exists
    [ -f "${keypath}.pub" ] && rm -f "${keypath}.pub" 2>/dev/null
  fi

  cfg_remove "$machine_name"
  log_event info "cli.unpair.done" "unpaired $machine_name" "{\"machine\":\"$machine_name\"}"
  printf '\n'
  ok "Unpaired \"$machine_name\"."
  printf '\n'
}

cmd_unpair_help() {
  printf 'Usage: agent-bridge unpair <machine>\n\n'
  printf 'Remove a paired machine and its SSH key.\n'
}

# -- config -------------------------------------------------------------------
cmd_config() {
  local machine_name=""
  local internet_host="" internet_port="" identity_file=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --internet-host)
        [ $# -lt 2 ] && die "--internet-host requires a value."
        internet_host="$2"; shift 2 ;;
      --internet-port)
        [ $# -lt 2 ] && die "--internet-port requires a value."
        internet_port="$2"; shift 2 ;;
      --identity-file)
        [ $# -lt 2 ] && die "--identity-file requires a value."
        identity_file="$2"; shift 2 ;;
      --help|-h)        cmd_config_help; exit 0 ;;
      -*)               die "Unknown option: $1. Use --help for usage." ;;
      *)
        if [ -z "$machine_name" ]; then
          machine_name="$1"
        else
          die "Unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge config <machine> [OPTIONS]"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  if [ -z "$internet_host" ] && [ -z "$internet_port" ] && [ -z "$identity_file" ]; then
    # Show current config
    local host port user ihost iport ident
    host="$(cfg_get "$machine_name" host 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
    user="$(cfg_get "$machine_name" user 2>/dev/null || printf 'unknown')"
    ihost="$(cfg_get "$machine_name" internet_host 2>/dev/null || true)"
    iport="$(cfg_get "$machine_name" internet_port 2>/dev/null || true)"
    ident="$(cfg_identity_file "$machine_name")"

    printf '\n'
    printf "${BOLD}  %s${RESET}\n" "$machine_name"
    printf "${DIM}    host=%s${RESET}\n" "$host"
    printf "${DIM}    port=%s${RESET}\n" "$port"
    printf "${DIM}    user=%s${RESET}\n" "$user"
    if [ -n "$ident" ]; then
      printf "${DIM}    identity_file=%s${RESET}\n" "$ident"
    fi
    if [ -n "$ihost" ]; then
      printf "${DIM}    internet_host=%s${RESET}\n" "$ihost"
    fi
    if [ -n "$iport" ]; then
      printf "${DIM}    internet_port=%s${RESET}\n" "$iport"
    fi
    printf '\n'
    return
  fi

  if [ -n "$internet_host" ]; then
    # Validate: no newlines, no brackets, no equals signs, no whitespace
    if printf '%s' "$internet_host" | grep -qE '[[:space:]\[\]=]|^$' 2>/dev/null; then
      die "Invalid internet_host: must not contain whitespace, brackets, or '=' characters."
    fi
    cfg_set "$machine_name" "internet_host" "$internet_host"
    ok "Set internet_host=$internet_host for $machine_name"
  fi

  if [ -n "$internet_port" ]; then
    # Validate: must be an integer 1-65535
    if ! [[ "$internet_port" =~ ^[0-9]+$ ]] || [ "$internet_port" -lt 1 ] || [ "$internet_port" -gt 65535 ]; then
      die "Invalid internet_port: must be an integer between 1 and 65535."
    fi
    cfg_set "$machine_name" "internet_port" "$internet_port"
    ok "Set internet_port=$internet_port for $machine_name"
  fi
  if [ -n "$identity_file" ]; then
    identity_file="${identity_file/#\~/$HOME}"
    if printf '%s' "$identity_file" | grep -qE '[[:space:]\[\]=]|^$' 2>/dev/null; then
      die "Invalid identity_file: must not contain whitespace, brackets, or '=' characters."
    fi
    if [ ! -f "$identity_file" ]; then
      die "Identity file not found: $identity_file"
    fi
    cfg_set "$machine_name" "identity_file" "$identity_file"
    # Keep the legacy key= field in sync for older installed MCP/plugin builds.
    cfg_set "$machine_name" "key" "$identity_file"
    ok "Set identity_file=$identity_file for $machine_name"
  fi
  printf '\n'
}

cmd_config_help() {
  printf 'Usage: agent-bridge config <machine> [OPTIONS]\n\n'
  printf 'View or update configuration for a paired machine.\n\n'
  printf 'With no options, prints the current config for the machine.\n\n'
  printf 'Options:\n'
  printf '  --internet-host <host>   Set the internet-reachable hostname or IP.\n'
  printf '                           Recommended: a Tailscale 100.x.y.z address.\n'
  printf '                           See README section "Internet connectivity (Tailscale)".\n'
  printf '  --internet-port <port>   Set the internet-reachable SSH port (default: 22)\n'
  printf '  --identity-file <path>   Set the SSH IdentityFile for this peer (also updates legacy key=)\n'
  printf '  -h, --help               Show this help\n\n'
  printf 'Examples:\n'
  printf '  agent-bridge config MacBook-Pro\n'
  printf '  agent-bridge config MacBook-Pro --internet-host 100.126.23.87\n'
  printf '  agent-bridge config MacBook-Pro --internet-host 100.126.23.87 --internet-port 22\n'
  printf '  agent-bridge config MacBook-Pro --identity-file ~/.agent-bridge/keys/agent-bridge_Mac-mini\n'
}

cmd_help() {
  printf '\n'
  printf "${BOLD}agent-bridge${RESET} v%s\n" "$VERSION"
  printf 'Bridge AI coding agents across machines.\n'
  printf 'Pure bash. Zero dependencies.\n'
  printf '\n'
  printf "${BOLD}Usage:${RESET}\n"
  printf '  agent-bridge <command> [options]\n'
  printf '\n'
  printf "${BOLD}Commands:${RESET}\n"
  printf '  setup              Enable SSH, generate keys, show pairing screen\n'
  printf '  pair               Pair with another machine (interactive or flags)\n'
  printf '  config <machine>   View or update machine config (--internet-host, --internet-port)\n'
  printf '  connect <machine>  Open an interactive SSH session\n'
  printf '  run <machine> "cmd"  Run a plain shell command on a paired machine (diagnostics only)\n'
  printf '  list               List all paired machines\n'
  printf '  status [machine]   Check reachability (internet_host if configured, else LAN; --probe is no-op)\n'
  printf '  reset-path <m>     Clear legacy path-cache files (compatibility; no endpoint-selection effect)\n'
  printf '  unpair <machine>   Remove a pairing\n'
  printf '  version            Show version\n'
  printf '  help               Show this help\n'
  printf '\n'
  printf "${BOLD}Agent-to-agent communication:${RESET}\n"
  printf "  Talking to the RUNNING agent on another machine is done via the\n"
  printf "  Claude Code channel plugin and its bridge_send_message MCP tool.\n"
  printf "  The CLI does NOT wrap or spawn agents — 'run' is shell-only.\n"
  printf '\n'
  printf "${BOLD}Same-machine delivery (3.5.0+):${RESET}\n"
  printf "  bridge_send_message also accepts the LOCAL machine name (or one of\n"
  printf "  the aliases 'local', 'self', 'localhost'). Same-machine sends write\n"
  printf "  the BridgeMessage JSON directly to ~/.agent-bridge/inbox/<target>/\n"
  printf "  with no SSH hop. Useful for routing to OpenClaw embedded agents on\n"
  printf "  the SAME host (e.g. target=openclaw/clawdiboi2). The receiver still\n"
  printf "  needs a watcher (Claude Code channel plugin or openclaw-channel).\n"
  printf '\n'
  printf "${BOLD}Examples:${RESET}\n"
  printf '  agent-bridge setup --name MacBook-Pro\n'
  printf '  agent-bridge pair --host 192.168.1.50 --user ethan --name MacBook-Pro --pubkey "ssh-ed25519 AAAA..."\n'
  printf '  agent-bridge run MacBook-Pro "ls -la ~/Projects"\n'
  printf '  agent-bridge run MacBook-Pro "cd ~/Projects/myapp && git pull"\n'
  printf '  agent-bridge connect MacBook-Pro\n'
  printf '\n'
  printf 'https://github.com/EthanSK/agent-bridge\n'
  printf '\n'
}

cmd_version() {
  printf 'agent-bridge %s\n' "$VERSION"
}

# -- Main dispatch ------------------------------------------------------------
main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    setup)    cmd_setup "$@" ;;
    pair)     cmd_pair "$@" ;;
    config)   cmd_config "$@" ;;
    connect)  cmd_connect "$@" ;;
    run)      cmd_run "$@" ;;
    list)     cmd_list "$@" ;;
    status)   cmd_status "$@" ;;
    reset-path) cmd_reset_path "$@" ;;
    unpair)   cmd_unpair "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h)       cmd_help ;;
    *)        die "Unknown command: $cmd. Run 'agent-bridge help' for usage." ;;
  esac
}

main "$@"
