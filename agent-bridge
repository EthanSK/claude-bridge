#!/usr/bin/env bash
set -euo pipefail

# agent-bridge — Bridge AI coding agents across machines.
# Pure bash. Zero dependencies. Works on any Mac/Linux out of the box.
# https://github.com/EthanSK/agent-bridge
#
# Previously known as claude-bridge.

INVOKED_AS="$(basename "$0")"

VERSION="3.2.0"

# -- Colours (ANSI) ----------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# -- Deprecation notice -------------------------------------------------------
if [ "$INVOKED_AS" = "claude-bridge" ]; then
  printf '\033[0;33m  [deprecated] "claude-bridge" has been renamed to "agent-bridge". Please update your scripts.\033[0m\n' >&2
fi

# -- Paths --------------------------------------------------------------------
CONFIG_DIR="$HOME/.agent-bridge"
CONFIG_FILE="$CONFIG_DIR/config"
KEYS_DIR="$CONFIG_DIR/keys"
PATH_CACHE_FILE="$CONFIG_DIR/path-cache.json"

# How long a cached last-success is "fresh". After this, we re-probe LAN-first.
PATH_CACHE_TTL_SECS="${AGENT_BRIDGE_PATH_CACHE_TTL:-3600}"
case "$PATH_CACHE_TTL_SECS" in
  ''|*[!0-9]*) PATH_CACHE_TTL_SECS=3600 ;;
esac

# Migrate from old config dir if it exists and new one doesn't
if [ ! -d "$CONFIG_DIR" ] && [ -d "$HOME/.claude-bridge" ]; then
  mv "$HOME/.claude-bridge" "$CONFIG_DIR"
fi

# -- Helpers ------------------------------------------------------------------
die()  { printf "${RED}  Error: %s${RESET}\n" "$1" >&2; exit 1; }
info() { printf "${CYAN}%s${RESET}\n" "$1"; }
ok()   { printf "${GREEN}  [ok] %s${RESET}\n" "$1"; }
warn() { printf "${YELLOW}  %s${RESET}\n" "$1"; }
dim()  { printf "${DIM}  %s${RESET}\n" "$1"; }

ensure_config_dir() {
  [ -d "$CONFIG_DIR" ] || mkdir -p "$CONFIG_DIR" && chmod 700 "$CONFIG_DIR"
  [ -d "$KEYS_DIR" ]   || mkdir -p "$KEYS_DIR"   && chmod 700 "$KEYS_DIR"
  [ -f "$CONFIG_FILE" ] || touch "$CONFIG_FILE"   && chmod 600 "$CONFIG_FILE"
}

# -- INI-style config parser --------------------------------------------------
# Config format:
#   [MacBook-Pro]
#   host=MacBookPro.local
#   user=ethansk
#   port=22
#   key=~/.agent-bridge/keys/MacBook-Pro
#   paired_at=2026-04-09T12:00:00

# Get a value for a machine: cfg_get <machine> <key>
cfg_get() {
  local machine="$1" key="$2"
  if [ ! -f "$CONFIG_FILE" ]; then
    return 1
  fi
  local in_section=0
  while IFS= read -r line || [ -n "$line" ]; do
    # Strip carriage returns
    line="${line%$'\r'}"
    # Check for section header (case-insensitive match)
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$(printf '%s' "$section" | tr '[:upper:]' '[:lower:]')" = "$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')" ]; then
        in_section=1
      else
        in_section=0
      fi
      continue
    fi
    if [ "$in_section" = "1" ] && [[ "$line" =~ ^${key}=(.*)$ ]]; then
      printf '%s' "${BASH_REMATCH[1]}"
      return 0
    fi
  done < "$CONFIG_FILE"
  return 1
}

# Check if a machine exists (case-insensitive)
cfg_exists() {
  local machine="$1"
  local lower_machine
  lower_machine="$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')"
  if [ ! -f "$CONFIG_FILE" ]; then
    return 1
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$(printf '%s' "$section" | tr '[:upper:]' '[:lower:]')" = "$lower_machine" ]; then
        return 0
      fi
    fi
  done < "$CONFIG_FILE"
  return 1
}

# Get the exact section name (preserving original case)
cfg_real_name() {
  local machine="$1"
  local lower_machine
  lower_machine="$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')"
  if [ ! -f "$CONFIG_FILE" ]; then
    return 1
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$(printf '%s' "$section" | tr '[:upper:]' '[:lower:]')" = "$lower_machine" ]; then
        printf '%s' "$section"
        return 0
      fi
    fi
  done < "$CONFIG_FILE"
  return 1
}

# Save a machine config (overwrites if exists)
cfg_save() {
  local machine="$1" host="$2" user="$3" port="$4" keypath="$5"
  ensure_config_dir

  # Remove existing section first
  cfg_remove "$machine" 2>/dev/null || true

  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # Expand ~ in keypath
  keypath="${keypath/#\~/$HOME}"

  {
    printf '[%s]\n' "$machine"
    printf 'host=%s\n' "$host"
    printf 'user=%s\n' "$user"
    printf 'port=%s\n' "$port"
    printf 'key=%s\n' "$keypath"
    printf 'paired_at=%s\n' "$ts"
    printf '\n'
  } >> "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
}

# Remove a machine section
cfg_remove() {
  local machine="$1"
  if ! cfg_exists "$machine"; then
    return 1
  fi
  local real_name
  real_name="$(cfg_real_name "$machine")"
  local tmpfile
  tmpfile="$(mktemp)"
  local in_section=0
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      if [ "$section" = "$real_name" ]; then
        in_section=1
        continue
      else
        in_section=0
      fi
    fi
    if [ "$in_section" = "1" ]; then
      # Skip lines in the removed section
      continue
    fi
    printf '%s\n' "$line"
  done < "$CONFIG_FILE" > "$tmpfile"
  mv "$tmpfile" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
}

# List all machine names
cfg_list_names() {
  if [ ! -f "$CONFIG_FILE" ]; then
    return
  fi
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      printf '%s\n' "${BASH_REMATCH[1]}"
    fi
  done < "$CONFIG_FILE"
}

# Set or update a single key within an existing machine section
cfg_set() {
  local machine="$1" key="$2" value="$3"
  if ! cfg_exists "$machine"; then
    die "Machine \"$machine\" not found in config."
  fi
  local real_name
  real_name="$(cfg_real_name "$machine")"
  local tmpfile
  tmpfile="$(mktemp)"
  local in_section=0 key_written=0
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%$'\r'}"
    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      local section="${BASH_REMATCH[1]}"
      # If leaving our section and we haven't written the key yet, append it
      if [ "$in_section" = "1" ] && [ "$key_written" = "0" ]; then
        printf '%s=%s\n' "$key" "$value" >> "$tmpfile"
        key_written=1
      fi
      if [ "$section" = "$real_name" ]; then
        in_section=1
      else
        in_section=0
      fi
      printf '%s\n' "$line" >> "$tmpfile"
      continue
    fi
    if [ "$in_section" = "1" ] && [[ "$line" =~ ^${key}= ]]; then
      # Replace existing key
      printf '%s=%s\n' "$key" "$value" >> "$tmpfile"
      key_written=1
      continue
    fi
    printf '%s\n' "$line" >> "$tmpfile"
  done < "$CONFIG_FILE"
  # If still in section at EOF and key not written, append it
  if [ "$in_section" = "1" ] && [ "$key_written" = "0" ]; then
    printf '%s=%s\n' "$key" "$value" >> "$tmpfile"
  fi
  mv "$tmpfile" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
}

# -- Last-reachable-path cache ------------------------------------------------
# Remembers which path (LAN vs internet) last worked per machine, so off-network
# ops don't eat a 3s LAN probe on every call. Stored at ~/.agent-bridge/path-cache.json,
# mode 0600. After PATH_CACHE_TTL_SECS of no successful activity on the cached path,
# the next call re-probes LAN-first. On a successful connection, we update the cache.
# Corrupt or missing files are treated as "no cache" — callers fall through to
# standard LAN-first probing.
#
# File shape:
#   {
#     "Mac-Mini":   {"path": "internet", "ts": 1776473474, "last_success": 1776473474},
#     "MacBookPro": {"path": "lan",      "ts": 1776473400, "last_success": 1776473400}
#   }

# Escape a string so it's safe to embed inside a JSON double-quoted value.
# Handles " and \ at minimum — machine names could contain either, which would
# otherwise corrupt the no-jq cache file. We also drop raw control characters
# (< 0x20) just in case.
#
# Note: the no-jq *reader* uses a regex that doesn't fully grok escaped
# quotes, so machines with literal `"` in their names won't be read back on
# jq-less systems. That's acceptable degradation (the caller just falls
# through to a LAN-first probe). jq is present on all modern macOS / Linux
# installs and handles these perfectly.
_path_cache_json_escape() {
  local s="$1"
  # Backslash must come first so we don't double-escape the \" substitution.
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  # Strip raw control characters (newlines, tabs, etc.) — they would also
  # produce invalid JSON. Machine names shouldn't have any in practice.
  s="$(printf '%s' "$s" | tr -d '\000-\037')"
  printf '%s' "$s"
}

# Extract a single field from an entry body parsed from the JSON cache.
_path_cache_field_from_body() {
  local body="$1" field="$2"
  if [ "$field" = "path" ]; then
    if [[ "$body" =~ \"path\"[[:space:]]*:[[:space:]]*\"([^\"]+)\" ]]; then
      printf '%s' "${BASH_REMATCH[1]}"
    fi
  else
    if [[ "$body" =~ \"${field}\"[[:space:]]*:[[:space:]]*([0-9]+) ]]; then
      printf '%s' "${BASH_REMATCH[1]}"
    fi
  fi
}

# Emit existing cache entries except <machine>, normalized to one line each.
# The no-jq reader/writer understands both compact entries and jq/TS pretty
# JSON, then rewrites compactly so future pure-bash reads stay reliable.
_path_cache_entries_except() {
  local machine="$1"
  [ -f "$PATH_CACHE_FILE" ] || return 0

  local lower_target
  lower_target="$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')"

  local line in_entry=0 skip_entry=0 entry_name="" body=""
  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$skip_entry" = "1" ]; then
      [[ "$line" == *"}"* ]] && skip_entry=0
      continue
    fi

    if [ "$in_entry" = "1" ]; then
      body="${body} ${line}"
      if [[ "$line" == *"}"* ]]; then
        local p ts last
        p="$(_path_cache_field_from_body "$body" path)"
        ts="$(_path_cache_field_from_body "$body" ts)"
        last="$(_path_cache_field_from_body "$body" last_success)"
        if [[ "$p" =~ ^(lan|internet)$ ]] && [[ "$ts" =~ ^[0-9]+$ ]] && [[ "$last" =~ ^[0-9]+$ ]]; then
          printf '"%s": {"path": "%s", "ts": %s, "last_success": %s}\n' "$entry_name" "$p" "$ts" "$last"
        fi
        in_entry=0
        entry_name=""
        body=""
      fi
      continue
    fi

    if [[ "$line" =~ \"([^\"]+)\"[[:space:]]*:[[:space:]]*\{(.*) ]]; then
      local name="${BASH_REMATCH[1]}"
      local lower_name
      lower_name="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"

      if [ "$lower_name" = "$lower_target" ]; then
        [[ "${BASH_REMATCH[2]}" != *"}"* ]] && skip_entry=1
        continue
      fi

      entry_name="$name"
      body="${BASH_REMATCH[2]}"
      if [[ "$body" == *"}"* ]]; then
        local p ts last
        p="$(_path_cache_field_from_body "$body" path)"
        ts="$(_path_cache_field_from_body "$body" ts)"
        last="$(_path_cache_field_from_body "$body" last_success)"
        if [[ "$p" =~ ^(lan|internet)$ ]] && [[ "$ts" =~ ^[0-9]+$ ]] && [[ "$last" =~ ^[0-9]+$ ]]; then
          printf '"%s": {"path": "%s", "ts": %s, "last_success": %s}\n' "$entry_name" "$p" "$ts" "$last"
        fi
        entry_name=""
        body=""
      else
        in_entry=1
      fi
    fi
  done < "$PATH_CACHE_FILE"
}

# Extract a single field from the JSON cache for a machine without jq.
# Usage: _path_cache_field_raw <machine> <field>
# Field must be one of: path, ts, last_success. Emits the raw value (strings
# are unquoted, numbers are left as-is) or empty string on miss.
_path_cache_field_raw() {
  local machine="$1" field="$2"
  [ -f "$PATH_CACHE_FILE" ] || return 0

  if command -v jq >/dev/null 2>&1; then
    # jq path: handle case-insensitive lookup so we match cfg_* helpers.
    local key
    key="$(jq -r --arg m "$machine" '
      (keys_unsorted[] | select(ascii_downcase == ($m | ascii_downcase)))
      // empty
    ' "$PATH_CACHE_FILE" 2>/dev/null || true)"
    [ -z "$key" ] && return 0
    jq -r --arg k "$key" --arg f "$field" '
      (.[$k][$f] // "") | tostring
    ' "$PATH_CACHE_FILE" 2>/dev/null || true
    return 0
  fi

  # Pure-bash fallback: parse compact entries plus jq/TS pretty JSON.
  local lower_machine
  lower_machine="$(printf '%s' "$machine" | tr '[:upper:]' '[:lower:]')"
  local line in_target=0 body=""
  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$in_target" = "1" ]; then
      body="${body} ${line}"
      if [[ "$line" == *"}"* ]]; then
        _path_cache_field_from_body "$body" "$field"
        return 0
      fi
      continue
    fi

    # Match: "MachineName": { ... } or the first line of a pretty entry.
    if [[ "$line" =~ \"([^\"]+)\"[[:space:]]*:[[:space:]]*\{(.*) ]]; then
      local name="${BASH_REMATCH[1]}"
      local lower_name
      lower_name="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"
      [ "$lower_name" != "$lower_machine" ] && continue
      body="${BASH_REMATCH[2]}"
      if [[ "$body" == *"}"* ]]; then
        _path_cache_field_from_body "$body" "$field"
        return 0
      else
        in_target=1
      fi
    fi
  done < "$PATH_CACHE_FILE"
}

# Get the cached path for a machine (echoes 'lan', 'internet', or empty).
path_cache_read() {
  local machine="$1"
  local path
  path="$(_path_cache_field_raw "$machine" path 2>/dev/null || true)"
  case "$path" in
    lan|internet) printf '%s' "$path" ;;
    *) : ;;  # empty / invalid => treat as miss
  esac
}

# Get seconds since the cached last_success for a machine (echoes an integer,
# or empty if no entry). A huge number effectively means "stale".
path_cache_age() {
  local machine="$1"
  local last
  last="$(_path_cache_field_raw "$machine" last_success 2>/dev/null || true)"
  [ -z "$last" ] && return 0
  [[ "$last" =~ ^[0-9]+$ ]] || return 0
  local now
  now="$(date +%s 2>/dev/null || printf '0')"
  printf '%d' "$((now - last))"
}

# Check if cache entry is fresh (exists and within TTL).
# Usage: path_cache_is_fresh <machine> -- returns 0 if fresh, 1 otherwise.
path_cache_is_fresh() {
  local machine="$1"
  local age
  age="$(path_cache_age "$machine")"
  [ -z "$age" ] && return 1
  [ "$age" -lt "$PATH_CACHE_TTL_SECS" ]
}

# Write (or update) a cache entry for <machine> with path=<lan|internet>.
# Atomic via mv-from-tmpfile. Mode 0600.
path_cache_write() {
  local machine="$1" new_path="$2"
  case "$new_path" in
    lan|internet) : ;;
    *) return 1 ;;
  esac
  ensure_config_dir
  local now
  now="$(date +%s 2>/dev/null || printf '0')"
  local tmp
  tmp="$(mktemp "${PATH_CACHE_FILE}.XXXXXX")" || return 1

  if command -v jq >/dev/null 2>&1; then
    local existing='{}'
    if [ -f "$PATH_CACHE_FILE" ]; then
      # If the file is corrupt, start fresh.
      existing="$(jq -c 'if type == "object" then . else {} end' "$PATH_CACHE_FILE" 2>/dev/null || printf '{}')"
    fi
    printf '%s' "$existing" | jq -r \
      --arg m "$machine" \
      --arg p "$new_path" \
      --argjson ts "$now" \
      '
        def one_line:
          to_entries as $entries
          | "{\n"
            + ($entries | map("  " + (.key | @json) + ": " + (.value | tojson)) | join(",\n"))
            + (if ($entries | length) > 0 then "\n" else "" end)
            + "}";
        # Strip any existing entry matching case-insensitively to avoid
        # duplicate keys that differ only in case.
        with_entries(select(.key | ascii_downcase != ($m | ascii_downcase)))
        + { ($m): { path: $p, ts: $ts, last_success: $ts } }
        | one_line
      ' > "$tmp" 2>/dev/null || {
        rm -f "$tmp"
        return 1
      }
  else
    # Pure-bash writer: emit one entry per line so our reader stays simple.
    # Carry forward other machines' entries verbatim (minus the target).
    local existing_entries
    existing_entries="$(_path_cache_entries_except "$machine")"
    {
      printf '{\n'
      local first=1
      local entry
      while IFS= read -r entry || [ -n "$entry" ]; do
        [ -z "$entry" ] && continue
        if [ "$first" = "1" ]; then
          printf '  %s' "$entry"
          first=0
        else
          printf ',\n  %s' "$entry"
        fi
      done <<< "$existing_entries"
      local _esc_machine
      _esc_machine="$(_path_cache_json_escape "$machine")"
      if [ "$first" = "1" ]; then
        printf '  "%s": {"path": "%s", "ts": %s, "last_success": %s}\n' \
          "$_esc_machine" "$new_path" "$now" "$now"
      else
        printf ',\n  "%s": {"path": "%s", "ts": %s, "last_success": %s}\n' \
          "$_esc_machine" "$new_path" "$now" "$now"
      fi
      printf '}\n'
    } > "$tmp"
  fi

  chmod 600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$PATH_CACHE_FILE"
  chmod 600 "$PATH_CACHE_FILE" 2>/dev/null || true
}

# Clear a cache entry for <machine>. If the file would become empty, remove it.
path_cache_clear() {
  local machine="$1"
  [ -f "$PATH_CACHE_FILE" ] || return 0
  local tmp
  tmp="$(mktemp "${PATH_CACHE_FILE}.XXXXXX")" || return 1

  if command -v jq >/dev/null 2>&1; then
    local existing='{}'
    existing="$(jq -c 'if type == "object" then . else {} end' "$PATH_CACHE_FILE" 2>/dev/null || printf '{}')"
    printf '%s' "$existing" | jq -r \
      --arg m "$machine" \
      '
        def one_line:
          to_entries as $entries
          | "{\n"
            + ($entries | map("  " + (.key | @json) + ": " + (.value | tojson)) | join(",\n"))
            + (if ($entries | length) > 0 then "\n" else "" end)
            + "}";
        with_entries(select(.key | ascii_downcase != ($m | ascii_downcase)))
        | one_line
      ' > "$tmp" 2>/dev/null || {
        rm -f "$tmp"
        return 1
      }
    # If cache is now empty ({}), just remove the file to keep things tidy.
    if [ "$(jq 'length' "$tmp" 2>/dev/null || printf '1')" = "0" ]; then
      rm -f "$tmp" "$PATH_CACHE_FILE"
      return 0
    fi
  else
    local existing_entries
    existing_entries="$(_path_cache_entries_except "$machine")"
    {
      printf '{\n'
      local first=1
      local entry
      while IFS= read -r entry || [ -n "$entry" ]; do
        [ -z "$entry" ] && continue
        if [ "$first" = "1" ]; then
          printf '  %s' "$entry"
          first=0
        else
          printf ',\n  %s' "$entry"
        fi
      done <<< "$existing_entries"
      printf '\n}\n'
    } > "$tmp"
    if [ "$first" != "0" ] && [ -s "$tmp" ]; then
      # No entries left — drop the file.
      rm -f "$tmp" "$PATH_CACHE_FILE"
      return 0
    fi
  fi

  chmod 600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$PATH_CACHE_FILE"
  chmod 600 "$PATH_CACHE_FILE" 2>/dev/null || true
}

# Print the order in which to attempt paths for <machine>, one per line.
# With cache bypass (PATH_CACHE_BYPASS=1), always emits "lan\ninternet".
# Otherwise: cached-fresh -> cached path first, alt second.
#           stale/missing -> lan first, internet second.
# Callers can iterate the output.
path_cache_order() {
  local machine="$1"
  if [ "${PATH_CACHE_BYPASS:-0}" = "1" ]; then
    printf 'lan\ninternet\n'
    return 0
  fi
  if path_cache_is_fresh "$machine"; then
    local cached
    cached="$(path_cache_read "$machine")"
    case "$cached" in
      lan)      printf 'lan\ninternet\n' ; return 0 ;;
      internet) printf 'internet\nlan\n' ; return 0 ;;
    esac
  fi
  printf 'lan\ninternet\n'
}

# -- SSH helpers with dual-endpoint fallback ----------------------------------
# Try cached path first (if fresh), fall back to the other. Timeouts: 3s for LAN
# when a fallback exists, 10s for internet, 10s when there's no fallback at all.
# Usage: ssh_with_fallback <machine> <ssh_args...>
# Sets SSH_FALLBACK_USED=1 if internet fallback was used.
SSH_FALLBACK_USED=0

# SSH exit 255 is ambiguous: it can mean "ssh itself failed to connect" OR
# "ssh connected fine and the remote command returned 255 on its own."
# Retrying on the alternate path for a remote 255 would duplicate side
# effects, so for exec paths we match ONLY explicit client-emitted
# connection-failure phrases. Elapsed-time heuristics are unsafe here: a
# long-running remote command that eventually exits 255 would look exactly
# like a slow ConnectTimeout.
#
# In practice OpenSSH always prints "ssh: connect to host X port Y: ..."
# or similar on real connection failures, so stderr sniffing is sufficient.
#
# Usage: _ssh_is_connection_failure <stderr-contents>
#   Returns 0 if stderr indicates a connection-level failure (safe to retry),
#   1 otherwise.
_ssh_is_connection_failure() {
  local stderr_text="${1:-}"

  # Known OpenSSH connection-failure signatures. We only match phrases that
  # the ssh *client* emits for its own failures (prefixed with "ssh:" or
  # "ssh_exchange_identification:") or unambiguously TCP/DNS-layer errors.
  # Generic words like "Permission denied" or "Broken pipe" are intentionally
  # avoided — remote commands can print those too.
  case "$stderr_text" in
    *"ssh: connect to host"*)                 return 0 ;;
    *"ssh: Could not resolve hostname"*)      return 0 ;;
    *"ssh_exchange_identification:"*)         return 0 ;;
    *"kex_exchange_identification:"*)         return 0 ;;
    *"Host key verification failed"*)         return 0 ;;
    *"Permission denied (publickey"*)         return 0 ;;
    *"No route to host"*)                     return 0 ;;
    *"Network is unreachable"*)               return 0 ;;
    *"Name or service not known"*)            return 0 ;;
  esac
  return 1
}

# Wall-clock timestamp in whole seconds.
_ssh_now_s() {
  date +%s 2>/dev/null || printf '0'
}

# Allow callers (e.g. `agent-bridge status --probe`) to force a fresh LAN-first
# probe by setting PATH_CACHE_BYPASS=1 before invoking the helpers.
PATH_CACHE_BYPASS="${PATH_CACHE_BYPASS:-0}"

ssh_build_args_for() {
  # Build SSH args for a specific host:port. When a client log path is
  # provided (5th arg), enable client-side diagnostics via -E at LogLevel=INFO
  # so connection failures are always captured even when stderr is silent.
  local machine="$1" host="$2" port="$3" timeout="$4"
  local client_log="${5:-}"
  local keypath
  keypath="$(cfg_get "$machine" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "ConnectTimeout=${timeout}" "-p" "$port")
  if [ -n "$client_log" ]; then
    args+=("-E" "$client_log" "-o" "LogLevel=INFO")
  else
    args+=("-o" "LogLevel=ERROR")
  fi
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath")
  fi
  args+=("$(cfg_get "$machine" user)@${host}")

  printf '%s\n' "${args[@]}"
}

ssh_exec_with_fallback() {
  local machine="$1"
  shift
  local extra_args=("$@")

  local host port internet_host internet_port
  host="$(cfg_get "$machine" host)" || die "Machine \"$machine\" not found."
  port="$(cfg_get "$machine" port 2>/dev/null || printf '22')"
  internet_host="$(cfg_get "$machine" internet_host 2>/dev/null || true)"
  internet_port="$(cfg_get "$machine" internet_port 2>/dev/null || printf '22')"

  local has_fallback=0
  [ -n "$internet_host" ] && has_fallback=1

  SSH_FALLBACK_USED=0

  # No internet fallback configured — single-path mode, no cache involvement.
  if [ "$has_fallback" = "0" ]; then
    local lan_args
    readarray -t lan_args < <(ssh_build_args_for "$machine" "$host" "$port" "10")
    lan_args+=("${extra_args[@]}")
    local lan_exit=0
    ssh "${lan_args[@]}" || lan_exit=$?
    # Any non-255 exit means SSH connected; the command's own exit code still
    # belongs to the caller, but the path itself is reachable.
    [ "$lan_exit" -ne 255 ] && path_cache_write "$machine" "lan" 2>/dev/null || true
    return "$lan_exit"
  fi

  # Both paths available. Try them in the cache-informed order.
  local order
  order="$(path_cache_order "$machine")"

  local last_exit=0
  local stderr_file client_log
  stderr_file="$(mktemp -t ab-ssh-err.XXXXXX)"
  client_log="$(mktemp -t ab-ssh-log.XXXXXX)"
  trap 'rm -f "$stderr_file" "$client_log"' RETURN
  local attempt
  while IFS= read -r attempt; do
    [ -z "$attempt" ] && continue
    local try_host try_port try_timeout
    if [ "$attempt" = "lan" ]; then
      try_host="$host"; try_port="$port"; try_timeout=3
    else
      try_host="$internet_host"; try_port="$internet_port"; try_timeout=10
    fi

    local try_args
    # Pass the client log path so ssh_build_args_for adds -E + LogLevel=INFO.
    # This captures connection-level failures even when stderr would be empty
    # under the default LogLevel=ERROR.
    readarray -t try_args < <(ssh_build_args_for "$machine" "$try_host" "$try_port" "$try_timeout" "$client_log")
    try_args+=("${extra_args[@]}")

    # Tee stderr so the user still sees it live and we can sniff it
    # afterwards to distinguish connection failures from a remote 255 exit.
    : > "$stderr_file"
    : > "$client_log"
    local try_exit=0
    ssh "${try_args[@]}" 2> >(tee "$stderr_file" >&2) || try_exit=$?
    # Give the tee subshell a moment to flush before we read.
    wait 2>/dev/null || true
    last_exit="$try_exit"

    if [ "$try_exit" -ne 255 ]; then
      # SSH connected (command may have failed, but the path is alive).
      path_cache_write "$machine" "$attempt" 2>/dev/null || true
      [ "$attempt" = "internet" ] && SSH_FALLBACK_USED=1
      return "$try_exit"
    fi

    # Exit 255 — ambiguous. Check both stderr and the captured client log for
    # the well-known connection-failure signatures. If neither has one, SSH
    # did connect and the remote command is what returned 255.
    local err_text
    err_text="$(cat "$stderr_file" "$client_log" 2>/dev/null || printf '')"
    if ! _ssh_is_connection_failure "$err_text"; then
      # Remote-side 255 on a live connection. Record the cache win and
      # return as-is.
      path_cache_write "$machine" "$attempt" 2>/dev/null || true
      [ "$attempt" = "internet" ] && SSH_FALLBACK_USED=1
      return "$try_exit"
    fi

    # Connection failure on this path — try the next.
  done <<< "$order"

  # Both paths failed with exit 255.
  return "$last_exit"
}

# -- Network helpers ----------------------------------------------------------
get_local_ip() {
  if command -v ipconfig >/dev/null 2>&1; then
    # macOS
    local ip
    ip="$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || true)"
    if [ -n "$ip" ]; then
      printf '%s' "$ip"
      return
    fi
  fi
  # Linux / fallback
  if command -v hostname >/dev/null 2>&1; then
    local ip
    ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
    if [ -n "$ip" ]; then
      printf '%s' "$ip"
      return
    fi
  fi
  # Last resort
  if command -v ifconfig >/dev/null 2>&1; then
    local ip
    ip="$(ifconfig 2>/dev/null | grep 'inet ' | grep -v '127.0.0.1' | head -1 | awk '{print $2}')"
    if [ -n "$ip" ]; then
      printf '%s' "$ip"
      return
    fi
  fi
  printf 'unknown'
}

get_public_ip() {
  curl -s --max-time 3 ifconfig.me 2>/dev/null || printf 'unavailable'
}

get_hostname() {
  hostname 2>/dev/null || printf 'unknown'
}

get_machine_name() {
  local h
  h="$(get_hostname)"
  # Strip .local suffix
  printf '%s' "${h%.local}"
}

get_username() {
  whoami 2>/dev/null || printf '%s' "$USER"
}

generate_pairing_token() {
  local hex
  hex="$(head -c 4 /dev/urandom | xxd -p | head -c 6)"
  printf 'bridge-%s' "$hex"
}

is_macos() {
  [ "$(uname -s)" = "Darwin" ]
}

# -- SSH helpers --------------------------------------------------------------
ssh_build_args() {
  local machine="$1"
  local host user port keypath
  host="$(cfg_get "$machine" host)" || die "Machine \"$machine\" not found."
  user="$(cfg_get "$machine" user)" || die "No user for \"$machine\"."
  port="$(cfg_get "$machine" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine" key 2>/dev/null || true)"

  # Expand ~ in keypath
  keypath="${keypath/#\~/$HOME}"

  local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-p" "$port")
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
    args+=("-i" "$keypath")
  fi
  args+=("${user}@${host}")

  printf '%s\n' "${args[@]}"
}

# -- Harness instruction files ------------------------------------------------
# After setup/pair, append agent-bridge instructions to detected AI harness
# config files (CLAUDE.md, AGENTS.md, GEMINI.md) so every new session knows
# about the bridge.

HARNESS_MARKER_START="<!-- agent-bridge:start -->"
HARNESS_MARKER_END="<!-- agent-bridge:end -->"

harness_instruction_block() {
  cat <<'BLOCK'
<!-- agent-bridge:start -->
## Agent Bridge

This machine has agent-bridge installed for cross-machine communication.

Paired machines (check with `agent-bridge list`):
- Run `agent-bridge status` to check which machines are reachable
- Run `agent-bridge run <machine> "command"` to execute a plain shell command remotely (diagnostics only — e.g. `git status`, `ls`, `ps aux`)
- Run `agent-bridge connect <machine>` for interactive SSH

To talk to the RUNNING agent on another paired machine, use the channel plugin's
`bridge_send_message` MCP tool. This is the ONLY supported way to communicate
agent-to-agent. `agent-bridge run` does NOT invoke a remote agent — it is a plain
remote-shell utility. There are no `--claude` / `--codex` / `--agent` flags.

Config: `~/.agent-bridge/config` | Keys: `~/.agent-bridge/keys/`

If a paired machine is unreachable, check if it's powered on and SSH (Remote Login) is enabled.
<!-- agent-bridge:end -->
BLOCK
}

# Update a single harness instruction file. Idempotent: replaces existing block
# or appends if not present.
# Usage: harness_update_file <filepath>
harness_update_file() {
  local filepath="$1"
  local block
  block="$(harness_instruction_block)"

  if [ ! -f "$filepath" ]; then
    # File doesn't exist — skip (we don't create files for harnesses that aren't installed)
    return 0
  fi

  if grep -qF "$HARNESS_MARKER_START" "$filepath" 2>/dev/null; then
    # Replace existing block between markers
    local tmpfile
    tmpfile="$(mktemp)"
    local in_block=0
    while IFS= read -r line || [ -n "$line" ]; do
      if [ "$line" = "$HARNESS_MARKER_START" ]; then
        in_block=1
        printf '%s\n' "$block" >> "$tmpfile"
        continue
      fi
      if [ "$in_block" = "1" ]; then
        if [ "$line" = "$HARNESS_MARKER_END" ]; then
          in_block=0
        fi
        continue
      fi
      printf '%s\n' "$line" >> "$tmpfile"
    done < "$filepath"
    mv "$tmpfile" "$filepath"
  else
    # Append block to end of file
    printf '\n%s\n' "$block" >> "$filepath"
  fi
}

# Detect installed harnesses and update their instruction files.
update_harness_instructions() {
  local updated=0

  # Claude Code: ~/.claude/CLAUDE.md
  if [ -f "$HOME/.claude/CLAUDE.md" ]; then
    harness_update_file "$HOME/.claude/CLAUDE.md"
    ok "Updated ~/.claude/CLAUDE.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  # Codex: ~/.codex/AGENTS.md
  if [ -f "$HOME/.codex/AGENTS.md" ]; then
    harness_update_file "$HOME/.codex/AGENTS.md"
    ok "Updated ~/.codex/AGENTS.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  # OpenClaw: ~/.openclaw/AGENTS.md
  if [ -f "$HOME/.openclaw/AGENTS.md" ]; then
    harness_update_file "$HOME/.openclaw/AGENTS.md"
    ok "Updated ~/.openclaw/AGENTS.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  # Gemini CLI: ~/.gemini/GEMINI.md
  if [ -f "$HOME/.gemini/GEMINI.md" ]; then
    harness_update_file "$HOME/.gemini/GEMINI.md"
    ok "Updated ~/.gemini/GEMINI.md with agent-bridge instructions."
    updated=$((updated + 1))
  fi

  if [ "$updated" -eq 0 ]; then
    dim "No AI harness instruction files detected. Skipping."
  fi
}

# -- Commands -----------------------------------------------------------------

cmd_setup() {
  local machine_name="" port="22"

  while [ $# -gt 0 ]; do
    case "$1" in
      --name|-n)             machine_name="$2"; shift 2 ;;
      --port|-p)             port="$2"; shift 2 ;;
      --help|-h)             cmd_setup_help; exit 0 ;;
      *)                     die "Unknown option: $1. Use --help for usage." ;;
    esac
  done

  [ -z "$machine_name" ] && machine_name="$(get_machine_name)"
  local user
  user="$(get_username)"
  local local_hostname
  local_hostname="$(get_hostname)"

  printf '\n'
  printf "${BOLD}${CYAN}  +----------------------------------------------+${RESET}\n"
  printf "${BOLD}${CYAN}  |         agent-bridge  .  setup                |${RESET}\n"
  printf "${BOLD}${CYAN}  +----------------------------------------------+${RESET}\n"
  printf '\n'

  # Step 1: Check/enable SSH
  printf "${BOLD}  1. SSH Server${RESET}\n"
  if is_macos; then
    local ssh_status
    ssh_status="$(sudo systemsetup -getremotelogin 2>/dev/null || printf 'unknown')"
    if printf '%s' "$ssh_status" | grep -qi 'on'; then
      ok "SSH (Remote Login) is already enabled."
    else
      dim "Enabling Remote Login (may require sudo)..."
      if sudo systemsetup -setremotelogin on 2>/dev/null; then
        ok "Remote Login enabled."
      else
        warn "Could not enable Remote Login automatically."
        warn "Enable it manually: System Settings > General > Sharing > Remote Login"
      fi
    fi
  else
    if systemctl is-active --quiet sshd 2>/dev/null || systemctl is-active --quiet ssh 2>/dev/null; then
      ok "SSH server is running."
    elif pgrep -x sshd >/dev/null 2>&1; then
      ok "SSH server is running."
    else
      warn "SSH server does not appear to be running."
      warn "Start it with: sudo systemctl start sshd"
    fi
  fi
  printf '\n'

  # Step 2: Generate key pair
  printf "${BOLD}  2. SSH Key Pair${RESET}\n"
  ensure_config_dir
  local key_path="$KEYS_DIR/agent-bridge_${machine_name}"
  local pub_key_path="${key_path}.pub"

  if [ -f "$key_path" ] && [ -f "$pub_key_path" ]; then
    dim "Using existing key pair."
  else
    dim "Generating SSH key pair..."
    ssh-keygen -t ed25519 -f "$key_path" -N "" -C "agent-bridge:${machine_name}" >/dev/null 2>&1
    chmod 600 "$key_path"
    ok "Key pair generated."
  fi

  # Save identity so pair/run/connect use the same key
  printf '%s' "$key_path" > "$CONFIG_DIR/.identity"

  # Add to authorized_keys
  local ssh_dir="$HOME/.ssh"
  local auth_keys="$ssh_dir/authorized_keys"
  [ -d "$ssh_dir" ] || mkdir -p "$ssh_dir" && chmod 700 "$ssh_dir"
  local pub_key
  pub_key="$(cat "$pub_key_path")"

  if [ -f "$auth_keys" ] && grep -qF "$pub_key" "$auth_keys" 2>/dev/null; then
    dim "Public key already in authorized_keys."
  else
    printf '%s\n' "$pub_key" >> "$auth_keys"
    chmod 600 "$auth_keys"
    ok "Public key added to authorized_keys."
  fi

  # Fingerprint
  local fingerprint
  fingerprint="$(ssh-keygen -lf "$pub_key_path" 2>/dev/null | awk '{print $2}' || printf 'unknown')"
  printf '\n'

  # Step 2b: Check Full Disk Access (macOS only)
  if is_macos; then
    printf "${BOLD}  2b. Full Disk Access${RESET}\n"
    # FDA cannot be reliably detected without root, and "ls ~/Desktop"
    # always succeeds locally. Just inform the user.
    warn "SSH sessions need Full Disk Access to reach Desktop, Documents, Downloads, etc."
    dim "Add /usr/sbin/sshd in System Settings > Privacy & Security > Full Disk Access."
    dim "Skip this if it's already there — you can always do it later."
    printf '\n'
  fi

  # Step 3: Get network info
  local primary_ip
  primary_ip="$(get_local_ip)"
  local public_ip
  public_ip="$(get_public_ip)"

  # Step 4: Generate pairing token
  printf "${BOLD}  3. Pairing Token${RESET}\n"
  local pairing_token
  pairing_token="$(generate_pairing_token)"
  ensure_config_dir
  printf '%s' "$pairing_token" > "$CONFIG_DIR/.pending-token"
  chmod 600 "$CONFIG_DIR/.pending-token"
  ok "One-time pairing token generated."
  printf '\n'

  # Step 5: Display pairing screen
  # Calculate box width — wide enough for the public key
  local pub_key_display="$pub_key"
  local pub_key_len=${#pub_key_display}
  local min_width=46
  local needed_width=$(( pub_key_len + 16 ))
  local box_width=$min_width
  [ "$needed_width" -gt "$box_width" ] && box_width=$needed_width
  local inner_width=$((box_width - 4))

  printf '\n'
  printf "${BOLD}${CYAN}"
  printf '  ╔'; printf '═%.0s' $(seq 1 $box_width); printf '╗\n'
  printf '  ║%*s%s%*s║\n' $(( (box_width - 21) / 2 )) "" "agent-bridge pairing" $(( (box_width - 20) / 2 )) ""
  printf '  ╠'; printf '═%.0s' $(seq 1 $box_width); printf '╣\n'
  printf "${RESET}"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Machine:${RESET}    %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$machine_name"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}User:${RESET}       %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$user"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Local:${RESET}      %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$local_hostname"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Local IP:${RESET}   %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$primary_ip"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Public IP:${RESET}  %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$public_ip"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Port:${RESET}       %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$port"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Token:${RESET}      ${YELLOW}${BOLD}%-*s${RESET}${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$pairing_token"
  printf "${BOLD}${CYAN}  ╠"; printf '═%.0s' $(seq 1 $box_width); printf "╣${RESET}\n"
  printf "${BOLD}${CYAN}  ║${RESET}  ${BOLD}Public Key:${RESET} %-*s${BOLD}${CYAN}║${RESET}\n" $((box_width - 14)) "$pub_key_display"
  printf "${BOLD}${CYAN}"
  printf '  ╚'; printf '═%.0s' $(seq 1 $box_width); printf '╝\n'
  printf "${RESET}"
  printf '\n'
  dim "Photograph this screen and send to Claude on your other machine."
  dim "For internet access across networks, see 'Internet connectivity (Tailscale)' in the README."
  printf '\n'

  # Manual pairing string (includes public key — no password needed)
  printf "${BOLD}${CYAN}  Pairing command (run on the other machine):${RESET}\n"
  printf '\n'
  printf "${DIM}  agent-bridge pair \\\\${RESET}\n"
  printf "${DIM}    --name \"%s\" \\\\${RESET}\n" "$machine_name"
  printf "${DIM}    --host \"%s\" \\\\${RESET}\n" "$primary_ip"
  printf "${DIM}    --port %s \\\\${RESET}\n" "$port"
  printf "${DIM}    --user \"%s\" \\\\${RESET}\n" "$user"
  printf "${DIM}    --token \"%s\" \\\\${RESET}\n" "$pairing_token"
  printf "${DIM}    --pubkey \"%s\"${RESET}\n" "$pub_key"
  printf '\n'

  printf "${BOLD}  Fingerprint:      ${DIM}%s${RESET}\n" "$fingerprint"
  printf '\n'
  dim "No password required. The other machine adds your public key to its"
  dim "authorized_keys, authorizing this machine to SSH in."
  printf '\n'

  # Step: Update AI harness instruction files
  printf "${BOLD}  4. AI Harness Instructions${RESET}\n"
  update_harness_instructions
  printf '\n'

  ok "Setup complete. This screen will stay visible."
  dim "Press Ctrl+C to close."
  printf '\n'

  # Keep process alive so user can photograph
  cleanup() {
    printf "\n"
  }
  trap cleanup EXIT INT TERM
  while true; do sleep 86400; done
}

cmd_setup_help() {
  printf 'Usage: agent-bridge setup [OPTIONS]\n\n'
  printf 'Enables SSH, generates keys, and displays a pairing screen.\n'
  printf 'Run on each machine you want to bridge.\n\n'
  printf 'Options:\n'
  printf '  -n, --name <name>   Machine name (defaults to hostname)\n'
  printf '  -p, --port <port>   SSH port (default: 22)\n'
  printf '  -h, --help          Show this help\n\n'
  printf 'Internet connectivity (off-LAN):\n'
  printf '  Install Tailscale on each machine, then use its 100.x.y.z IP as\n'
  printf '  internet_host on the paired machine:\n'
  printf '    agent-bridge config <machine> --internet-host <tailscale-ip>\n'
  printf '  See: https://github.com/EthanSK/agent-bridge#internet-connectivity-tailscale\n'
}

cmd_pair() {
  local machine_name="" host="" user="" port="22" keypath="" token="" pubkey=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --name|-n)    machine_name="$2"; shift 2 ;;
      --host|-H)    host="$2"; shift 2 ;;
      --user|-u)    user="$2"; shift 2 ;;
      --port|-p)    port="$2"; shift 2 ;;
      --key|-k)     keypath="$2"; shift 2 ;;
      --token|-t)   token="$2"; shift 2 ;;
      --pubkey)     pubkey="$2"; shift 2 ;;
      --manual|-m)  shift ;;  # No-op, kept for compat
      --help|-h)    cmd_pair_help; exit 0 ;;
      -*)           die "Unknown option: $1. Use --help for usage." ;;
      *)
        # Positional argument — could be a JSON/text file
        if [ -f "$1" ]; then
          dim "File pairing not supported in bash version. Use --name/--host/--user flags."
          exit 1
        fi
        die "Unknown argument: $1"
        ;;
    esac
  done

  # Interactive mode if missing required fields
  if [ -z "$host" ] || [ -z "$user" ]; then
    printf '\n'
    printf "${BOLD}${CYAN}  agent-bridge pair${RESET}\n"
    printf '\n'

    if [ -z "$machine_name" ]; then
      printf '  Machine name: '
      read -r machine_name
    fi
    if [ -z "$host" ]; then
      printf '  Host (IP or hostname): '
      read -r host
    fi
    if [ -z "$user" ]; then
      printf '  User: '
      read -r user
    fi
    printf '  Port [%s]: ' "$port"
    read -r input_port
    [ -n "$input_port" ] && port="$input_port"

    if [ -z "$token" ]; then
      printf '  Pairing token (from setup screen): '
      read -r token
    fi

    if [ -z "$pubkey" ]; then
      printf '  Public key from the other machine'\''s setup screen:\n'
      printf '  > '
      read -r pubkey
    fi
  fi

  [ -z "$machine_name" ] && machine_name="$host"
  [ -z "$host" ] && die "Host is required."
  [ -z "$user" ] && die "User is required."
  [ -z "$token" ] && die "Pairing token is required. Check the setup screen on the other machine."
  [ -z "$pubkey" ] && die "Public key is required. Copy it from the other machine's setup screen."

  printf '\n'
  printf "${BOLD}${CYAN}  agent-bridge pair${RESET}\n"
  printf '\n'

  # Step 1: Generate local key pair (if not already present and no --key override)
  ensure_config_dir
  local local_machine
  local_machine="$(get_machine_name)"
  local local_key="$KEYS_DIR/agent-bridge_${local_machine}"
  local local_pub="${local_key}.pub"

  if [ -n "$keypath" ]; then
    # User supplied a specific key — use it as-is (override mode)
    keypath="${keypath/#\~/$HOME}"
    printf "${BOLD}  1. SSH Key${RESET}\n"
    if [ -f "$keypath" ]; then
      ok "Using provided key: $keypath"
    else
      die "Key file not found: $keypath"
    fi
  else
    # Default: use the key from setup (saved in .identity), or fall back to hostname-based key
    printf "${BOLD}  1. Local Key Pair${RESET}\n"
    if [ -f "$CONFIG_DIR/.identity" ]; then
      local_key="$(cat "$CONFIG_DIR/.identity")"
      local_pub="${local_key}.pub"
      dim "Using setup key: $(basename "$local_key")"
    fi
    if [ -f "$local_key" ] && [ -f "$local_pub" ]; then
      dim "Key pair found for $local_machine."
    else
      dim "Generating SSH key pair for $local_machine..."
      ssh-keygen -t ed25519 -f "$local_key" -N "" -C "agent-bridge:${local_machine}" >/dev/null 2>&1
      chmod 600 "$local_key"
      ok "Key pair generated: $local_key"
    fi
    keypath="$local_key"
  fi
  printf '\n'

  # Step 2: Authorize the other machine's public key on THIS machine
  printf "${BOLD}  2. Authorize Remote Key${RESET}\n"
  local ssh_dir="$HOME/.ssh"
  local auth_keys="$ssh_dir/authorized_keys"
  [ -d "$ssh_dir" ] || mkdir -p "$ssh_dir" && chmod 700 "$ssh_dir"

  if [ -f "$auth_keys" ] && grep -qF "$pubkey" "$auth_keys" 2>/dev/null; then
    dim "Public key already in authorized_keys."
  else
    printf '%s\n' "$pubkey" >> "$auth_keys"
    sort -u "$auth_keys" -o "$auth_keys"
    chmod 600 "$auth_keys"
    ok "Remote public key added to ~/.ssh/authorized_keys."
  fi
  dim "The other machine can now SSH into this one."
  printf '\n'

  # Step 3: Token accepted as human-verification (no remote check)
  printf "${BOLD}  3. Token Verification${RESET}\n"
  ok "Token accepted: $token"
  dim "Token is recorded for human verification (no remote connection needed)."
  printf '\n'

  # Step 4: Save pairing config
  cfg_save "$machine_name" "$host" "$user" "$port" "$keypath"

  printf "${GREEN}${BOLD}  [ok] Paired with \"%s\"!${RESET}\n" "$machine_name"
  printf '\n'
  printf "  Connection details:\n"
  printf "${DIM}    Host:     %s${RESET}\n" "$host"
