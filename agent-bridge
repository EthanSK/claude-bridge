cmd_connect() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_connect_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge connect <machine>"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  local host user port keypath internet_host internet_port
  host="$(cfg_get "$machine_name" host)"
  user="$(cfg_get "$machine_name" user)"
  port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"
  internet_host="$(cfg_get "$machine_name" internet_host 2>/dev/null || true)"
  internet_port="$(cfg_get "$machine_name" internet_port 2>/dev/null || printf '22')"

  local has_fallback=0
  [ -n "$internet_host" ] && has_fallback=1

  printf '\n'
  printf "${CYAN}  Connecting to ${BOLD}%s${RESET}${CYAN} (%s@%s)...${RESET}\n" "$machine_name" "$user" "$host"
  printf '\n'

  # Build the ordered list of paths to try (cache-informed).
  local order
  if [ "$has_fallback" = "1" ]; then
    order="$(path_cache_order "$machine_name")"
  else
    order="lan"
  fi

  local exit_code=0
  local attempt announced_fallback=0
  while IFS= read -r attempt; do
    [ -z "$attempt" ] && continue
    local try_host try_port try_timeout
    if [ "$attempt" = "lan" ]; then
      try_host="$host"; try_port="$port"
      try_timeout=10
      [ "$has_fallback" = "1" ] && try_timeout=3
    else
      try_host="$internet_host"; try_port="$internet_port"
      try_timeout=10
    fi

    if [ "$announced_fallback" = "1" ]; then
      dim "Trying ${attempt} path (${try_host}:${try_port})..."
      printf '\n'
    fi

    local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "LogLevel=ERROR" "-o" "ConnectTimeout=${try_timeout}" "-p" "$try_port")
    if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
      args+=("-i" "$keypath")
    fi
    args+=("${user}@${try_host}")

    exit_code=0
    local start_s end_s elapsed_s
    start_s="$(_ssh_now_s)"
    ssh "${args[@]}" || exit_code=$?
    end_s="$(_ssh_now_s)"
    elapsed_s=$((end_s - start_s))

    if [ "$exit_code" -ne 255 ]; then
      # Connected (or connected then exited cleanly). Record success.
      path_cache_write "$machine_name" "$attempt" 2>/dev/null || true
      break
    fi

    # Exit 255 with an interactive session — stderr goes straight to the
    # user's terminal (we don't tee here, to avoid disturbing TUI apps), so
    # rely on elapsed wall-clock alone. There are three regimes:
    #
    #   elapsed >= try_timeout          => looks exactly like a ConnectTimeout
    #                                      failure. Retry alternate.
    #   elapsed >= try_timeout + 2 secs => definitely connected (user ran stuff).
    #                                      Don't retry.
    #   elapsed < try_timeout           => too quick to be a timeout. Could be
    #                                      either a fast connection failure
    #                                      (refused/unreachable) or a user
    #                                      hitting `exit 255` immediately.
    #                                      Retry alternate — a real user
    #                                      session would normally last longer,
    #                                      and a retry only pops another
    #                                      interactive session that the user
    #                                      can immediately exit if unwanted.
    local session_floor=$((try_timeout + 2))
    if [ "$elapsed_s" -ge "$session_floor" ]; then
      # Must have connected and the user actually used the session. Don't retry.
      path_cache_write "$machine_name" "$attempt" 2>/dev/null || true
      break
    fi

    # Connection failure on this path — note and loop for the next one.
    printf '\n'
    dim "${attempt} connection failed (SSH exit 255, ${elapsed_s}s)."
    announced_fallback=1
  done <<< "$order"

  printf '\n'
  if [ "$exit_code" -eq 0 ]; then
    dim "Connection closed."
  else
    printf "${YELLOW}  SSH exited with code %d.${RESET}\n" "$exit_code"
  fi
}

cmd_connect_help() {
  printf 'Usage: agent-bridge connect <machine>\n\n'
  printf 'Open an interactive SSH session to a paired machine.\n'
}

cmd_run() {
  local machine_name="" command=""

  # Parse args — machine and command are positional
  while [ $# -gt 0 ]; do
    case "$1" in
      --agent|--claude|--codex)
        die "The $1 flag was removed in agent-bridge 3.0.0. 'agent-bridge run' is a plain remote-shell utility only — it does NOT spawn agents. To talk to the running agent on another machine, use the channel plugin's bridge_send_message MCP tool."
        ;;
      --help|-h) cmd_run_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)
        if [ -z "$machine_name" ]; then
          machine_name="$1"
        elif [ -z "$command" ]; then
          command="$1"
        else
          die "Unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge run <machine> \"shell command\""
  [ -z "$command" ] && die "Command required. Usage: agent-bridge run <machine> \"shell command\""

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  local host user port keypath internet_host internet_port
  host="$(cfg_get "$machine_name" host)"
  user="$(cfg_get "$machine_name" user)"
  port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"
  internet_host="$(cfg_get "$machine_name" internet_host 2>/dev/null || true)"
  internet_port="$(cfg_get "$machine_name" internet_port 2>/dev/null || printf '22')"

  local has_fallback=0
  [ -n "$internet_host" ] && has_fallback=1

  printf "${DIM}  Running command on %s...${RESET}\n" "$machine_name"

  # Cache-informed attempt order (LAN-first when no cache or stale).
  local order
  if [ "$has_fallback" = "1" ]; then
    order="$(path_cache_order "$machine_name")"
  else
    order="lan"
  fi

  local exit_code=0
  local stderr_file client_log
  stderr_file="$(mktemp -t ab-ssh-err.XXXXXX)"
  client_log="$(mktemp -t ab-ssh-log.XXXXXX)"
  trap 'rm -f "$stderr_file" "$client_log"' EXIT
  local attempt
  while IFS= read -r attempt; do
    [ -z "$attempt" ] && continue
    local try_host try_port try_timeout
    if [ "$attempt" = "lan" ]; then
      try_host="$host"; try_port="$port"
      try_timeout=10
      [ "$has_fallback" = "1" ] && try_timeout=3
    else
      try_host="$internet_host"; try_port="$internet_port"
      try_timeout=10
    fi

    # Capture client-side SSH diagnostics via -E so connection failures are
    # always visible even when stderr would be silent.
    local args=("-o" "StrictHostKeyChecking=no" "-o" "UserKnownHostsFile=/dev/null" "-o" "ConnectTimeout=${try_timeout}" "-p" "$try_port" "-E" "$client_log" "-o" "LogLevel=INFO")
    if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ]; then
      args+=("-i" "$keypath")
    fi
    args+=("${user}@${try_host}" "$command")

    # Tee stderr so the user sees it live AND we can sniff it to tell a
    # connection failure apart from a remote command exiting 255.
    : > "$stderr_file"
    : > "$client_log"
    exit_code=0
    ssh "${args[@]}" 2> >(tee "$stderr_file" >&2) || exit_code=$?
    wait 2>/dev/null || true

    if [ "$exit_code" -ne 255 ]; then
      # SSH connected — remote command's exit code is authoritative.
      path_cache_write "$machine_name" "$attempt" 2>/dev/null || true
      break
    fi

    # Exit 255 — figure out if this was a connection failure or the remote
    # command exiting 255 itself. Check both stderr and the client log.
    local err_text
    err_text="$(cat "$stderr_file" "$client_log" 2>/dev/null || printf '')"
    if ! _ssh_is_connection_failure "$err_text"; then
      # Remote-side 255 on a live connection. Don't retry — record the cache.
      path_cache_write "$machine_name" "$attempt" 2>/dev/null || true
      break
    fi

    # Connection failure — try the alternate path when one is configured.
    if [ "$has_fallback" = "1" ]; then
      dim "${attempt} connection failed (SSH exit 255), trying alternate path..."
    fi
  done <<< "$order"

  printf '\n'
  if [ "$exit_code" -eq 0 ]; then
    ok "command completed on $machine_name (exit 0)"
  else
    printf "${YELLOW}  command on %s exited with code %d.${RESET}\n" "$machine_name" "$exit_code"
  fi

  exit "$exit_code"
}

