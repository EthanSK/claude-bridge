}

# -- reset-path ---------------------------------------------------------------
cmd_reset_path() {
  local machine_name="" all=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --all)     all=1; shift ;;
      --help|-h) cmd_reset_path_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  if [ "$all" = "1" ]; then
    if [ -f "$PATH_CACHE_FILE" ]; then
      rm -f "$PATH_CACHE_FILE"
      ok "Cleared path cache for all machines."
    else
      dim "No path cache to clear."
    fi
    return 0
  fi

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge reset-path <machine> (or --all)"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  path_cache_clear "$machine_name"
  ok "Cleared cached reachable path for $machine_name. Next call will re-probe LAN-first."
}

cmd_reset_path_help() {
  printf 'Usage: agent-bridge reset-path <machine>\n'
  printf '       agent-bridge reset-path --all\n\n'
  printf 'Invalidate the cached last-reachable-path (LAN vs internet) for a\n'
  printf 'machine. The next SSH/ops call will re-probe LAN-first.\n\n'
  printf 'The cache lives at ~/.agent-bridge/path-cache.json and is normally\n'
  printf 'self-managed — only touch it if routing/network topology changes in\n'
  printf 'a way agent-bridge cannot detect on its own.\n'
}

cmd_unpair() {
  local machine_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --help|-h) cmd_unpair_help; exit 0 ;;
      -*)        die "Unknown option: $1" ;;
      *)         machine_name="$1"; shift ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge unpair <machine>"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  # Try to remove the key file
  local keypath
  keypath="$(cfg_get "$machine_name" key 2>/dev/null || true)"
  keypath="${keypath/#\~/$HOME}"
  if [ -n "$keypath" ] && [ "$keypath" != "(system default)" ] && [ -f "$keypath" ]; then
    rm -f "$keypath" 2>/dev/null && dim "Removed key: $keypath" || warn "Could not remove key at $keypath"
    # Also remove .pub if it exists
    [ -f "${keypath}.pub" ] && rm -f "${keypath}.pub" 2>/dev/null
  fi

  cfg_remove "$machine_name"
  printf '\n'
  ok "Unpaired \"$machine_name\"."
  printf '\n'
}

cmd_unpair_help() {
  printf 'Usage: agent-bridge unpair <machine>\n\n'
  printf 'Remove a paired machine and its SSH key.\n'
}

# -- config -------------------------------------------------------------------
cmd_config() {
  local machine_name=""
  local internet_host="" internet_port=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --internet-host)
        [ $# -lt 2 ] && die "--internet-host requires a value."
        internet_host="$2"; shift 2 ;;
      --internet-port)
        [ $# -lt 2 ] && die "--internet-port requires a value."
        internet_port="$2"; shift 2 ;;
      --help|-h)        cmd_config_help; exit 0 ;;
      -*)               die "Unknown option: $1. Use --help for usage." ;;
      *)
        if [ -z "$machine_name" ]; then
          machine_name="$1"
        else
          die "Unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [ -z "$machine_name" ] && die "Machine name required. Usage: agent-bridge config <machine> --internet-host <host>"

  if ! cfg_exists "$machine_name"; then
    die "Machine \"$machine_name\" not found. Run 'agent-bridge list' to see paired machines."
  fi

  if [ -z "$internet_host" ] && [ -z "$internet_port" ]; then
    # Show current config
    local host port user ihost iport
    host="$(cfg_get "$machine_name" host 2>/dev/null || printf 'unknown')"
    port="$(cfg_get "$machine_name" port 2>/dev/null || printf '22')"
    user="$(cfg_get "$machine_name" user 2>/dev/null || printf 'unknown')"
    ihost="$(cfg_get "$machine_name" internet_host 2>/dev/null || true)"
    iport="$(cfg_get "$machine_name" internet_port 2>/dev/null || true)"

    printf '\n'
    printf "${BOLD}  %s${RESET}\n" "$machine_name"
    printf "${DIM}    host=%s${RESET}\n" "$host"
    printf "${DIM}    port=%s${RESET}\n" "$port"
    printf "${DIM}    user=%s${RESET}\n" "$user"
    if [ -n "$ihost" ]; then
      printf "${DIM}    internet_host=%s${RESET}\n" "$ihost"
    fi
    if [ -n "$iport" ]; then
      printf "${DIM}    internet_port=%s${RESET}\n" "$iport"
    fi
    printf '\n'
    return
  fi

  if [ -n "$internet_host" ]; then
    # Validate: no newlines, no brackets, no equals signs, no whitespace
    if printf '%s' "$internet_host" | grep -qE '[[:space:]\[\]=]|^$' 2>/dev/null; then
      die "Invalid internet_host: must not contain whitespace, brackets, or '=' characters."
    fi
    cfg_set "$machine_name" "internet_host" "$internet_host"
    ok "Set internet_host=$internet_host for $machine_name"
  fi

  if [ -n "$internet_port" ]; then
    # Validate: must be an integer 1-65535
    if ! [[ "$internet_port" =~ ^[0-9]+$ ]] || [ "$internet_port" -lt 1 ] || [ "$internet_port" -gt 65535 ]; then
      die "Invalid internet_port: must be an integer between 1 and 65535."
    fi
    cfg_set "$machine_name" "internet_port" "$internet_port"
    ok "Set internet_port=$internet_port for $machine_name"
  fi
  printf '\n'
}

cmd_config_help() {
  printf 'Usage: agent-bridge config <machine> [OPTIONS]\n\n'
  printf 'View or update configuration for a paired machine.\n\n'
  printf 'With no options, prints the current config for the machine.\n\n'
  printf 'Options:\n'
  printf '  --internet-host <host>   Set the internet-reachable hostname or IP.\n'
  printf '                           Recommended: a Tailscale 100.x.y.z address.\n'
  printf '                           See README section "Internet connectivity (Tailscale)".\n'
  printf '  --internet-port <port>   Set the internet-reachable SSH port (default: 22)\n'
  printf '  -h, --help               Show this help\n\n'
  printf 'Examples:\n'
  printf '  agent-bridge config MacBook-Pro\n'
  printf '  agent-bridge config MacBook-Pro --internet-host 100.126.23.87\n'
  printf '  agent-bridge config MacBook-Pro --internet-host 100.126.23.87 --internet-port 22\n'
}

cmd_help() {
  printf '\n'
  printf "${BOLD}agent-bridge${RESET} v%s\n" "$VERSION"
  printf 'Bridge AI coding agents across machines.\n'
  printf 'Pure bash. Zero dependencies.\n'
  printf '\n'
  printf "${BOLD}Usage:${RESET}\n"
  printf '  agent-bridge <command> [options]\n'
  printf '\n'
  printf "${BOLD}Commands:${RESET}\n"
  printf '  setup              Enable SSH, generate keys, show pairing screen\n'
  printf '  pair               Pair with another machine (interactive or flags)\n'
  printf '  config <machine>   View or update machine config (--internet-host, --internet-port)\n'
  printf '  connect <machine>  Open an interactive SSH session\n'
  printf '  run <machine> "cmd"  Run a plain shell command on a paired machine (diagnostics only)\n'
  printf '  list               List all paired machines\n'
  printf '  status [machine]   Check reachability (uses path cache; add --probe to force LAN-first)\n'
  printf '  reset-path <m>     Clear the cached LAN/internet path for a machine (or --all)\n'
  printf '  unpair <machine>   Remove a pairing\n'
  printf '  version            Show version\n'
  printf '  help               Show this help\n'
  printf '\n'
  printf "${BOLD}Agent-to-agent communication:${RESET}\n"
  printf "  Talking to the RUNNING agent on another machine is done via the\n"
  printf "  Claude Code channel plugin and its bridge_send_message MCP tool.\n"
  printf "  The CLI does NOT wrap or spawn agents — 'run' is shell-only.\n"
  printf '\n'
  printf "${BOLD}Examples:${RESET}\n"
  printf '  agent-bridge setup --name MacBook-Pro\n'
  printf '  agent-bridge pair --host 192.168.1.50 --user ethan --name MacBook-Pro --pubkey "ssh-ed25519 AAAA..."\n'
  printf '  agent-bridge run MacBook-Pro "ls -la ~/Projects"\n'
  printf '  agent-bridge run MacBook-Pro "cd ~/Projects/myapp && git pull"\n'
  printf '  agent-bridge connect MacBook-Pro\n'
  printf '\n'
  printf 'https://github.com/EthanSK/agent-bridge\n'
  printf '\n'
}

cmd_version() {
  printf 'agent-bridge %s\n' "$VERSION"
}

# -- Main dispatch ------------------------------------------------------------
main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    setup)    cmd_setup "$@" ;;
    pair)     cmd_pair "$@" ;;
    config)   cmd_config "$@" ;;
    connect)  cmd_connect "$@" ;;
    run)      cmd_run "$@" ;;
    list)     cmd_list "$@" ;;
    status)   cmd_status "$@" ;;
    reset-path) cmd_reset_path "$@" ;;
    unpair)   cmd_unpair "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h)       cmd_help ;;
    *)        die "Unknown command: $cmd. Run 'agent-bridge help' for usage." ;;
  esac
}

main "$@"
